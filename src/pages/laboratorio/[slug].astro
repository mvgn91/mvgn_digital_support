---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import ArrowLeft from '@lucide/astro/icons/arrow-left';
import ArticuloCard from '../../components/ArticuloCard.astro';
import AmbientGradient from '../../components/AmbientGradient';

export async function getStaticPaths() {
  const articulos = await getCollection('laboratorio');
  return articulos.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { data } = article;

const dateStr = new Date(data.pubDate).toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// ── Reading time (rough estimate: ~200 chars/min) ──
const bodyText = typeof article.body === 'string' ? article.body : '';
const readingTime = Math.max(1, Math.ceil(bodyText.length / 1000));

// ── Title split on em dash ──
const titleParts = data.title.split(' — ');
const brandPart = titleParts[0];
const descPart = titleParts.slice(1).join(' — ');

// ── Related articles ──
const todos = await getCollection('laboratorio');
const otros = todos.filter(a => a.id !== article.id);

// By shared tags (≥ 1 match), sorted descending by match count
function countMatches(a: typeof otros[0]): number {
  return a.data.tags.filter(t => data.tags.includes(t)).length;
}
const byTags = otros
  .filter(a => countMatches(a) > 0)
  .sort((a, b) => countMatches(b) - countMatches(a));

// Fallback: most recent (excl. current)
const byDate = otros
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const relacionados = byTags.length >= 2 ? byTags.slice(0, 3) : byDate.slice(0, 3);
---

<BaseLayout
  title={`${data.title} — MVGN Labs`}
  description={data.description}
>
  <div class="article-page">

    <div class="bg-layers" aria-hidden="true">
      <AmbientGradient client:load palette="purple" />
    </div>

      <article class="article">
        <nav class="article-nav">
          <a href="/laboratorio/" class="article-nav-link">
            <ArrowLeft size={16} />
            Volver al laboratorio
          </a>
          <a href="/" class="article-nav-link article-nav-link--home">
            Volver al inicio
          </a>
        </nav>

        <header class="article-header">
          <div class="article-header-meta">
            <span class="article-header-archive">
              <span class="archive-label">ARCHIVO</span>
              <span class="archive-value">{article.id}</span>
            </span>
            <span class="meta-sep" aria-hidden="true"></span>
            <span class="meta-item">{readingTime} MIN</span>
            <span class="meta-sep" aria-hidden="true"></span>
            <time class="meta-item" datetime={data.pubDate.toISOString()}>{dateStr}</time>
          </div>
          <div class="article-hero-grid">
            <h1 class="article-title">
              <span class="article-title-brand">{brandPart}</span>
              {descPart && <><span class="title-sep" aria-hidden="true">—</span><span class="article-title-desc">{descPart}</span></>}
            </h1>
            <div class="article-hero-side">
              {data.heroImage && (
                <img class="article-hero-thumb" src={data.heroImage} alt="" aria-hidden="true" loading="lazy" />
              )}
              <p class="article-desc">{data.description}</p>
            </div>
          </div>
          <div class="article-tags">
            {data.tags.map(tag => <span class="article-tag">{tag}</span>)}
          </div>
        </header>

        <div class="article-body">
          <Content />
        </div>

        <footer class="article-footer">
          <div class="article-footer-divider" aria-hidden="true"></div>
          <div class="article-footer-signature">
            <div class="signature-line"></div>
            <p class="signature-text">
              Este artículo fue investigado, escrito y revisado por el equipo de <strong>MVGN Labs</strong> como parte de nuestro laboratorio editorial. Cada herramienta que documentamos pasa por meses de uso real antes de llegar a esta página.
            </p>
            <div class="signature-author">
              <span class="signature-name">A. Ibañez</span>
              <span class="signature-role">Fundador · MVGN Labs</span>
            </div>
          </div>
          <div class="article-footer-nav">
            <a href="/laboratorio/" class="article-nav-link">
              <ArrowLeft size={16} />
              Volver al laboratorio
            </a>
            <a href="/" class="article-nav-link article-nav-link--home">
              Volver al inicio
            </a>
          </div>
        </footer>
      </article>

    <!-- ═══ RELATED ARTICLES ═══ -->
    {relacionados.length > 0 && (
      <section class="related-section">
        <header class="related-header">
          <h2 class="related-title">Artículos relacionados</h2>
          <p class="related-desc">Sigue explorando el laboratorio</p>
        </header>
        <div class="related-grid">
          {relacionados.map((rel, i) => (
            <div
              class="related-entry"
              style={`animation-delay: ${i * 120}ms`}
            >
              <ArticuloCard article={rel} />
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════
     ARTICLE PAGE — Editorial Magazine Layout
     ═══════════════════════════════════════════════════════ */

  .article-page {
    position: relative;
    min-height: 100vh;
    padding: 128px var(--space-8) var(--space-24);
  }

  /* ── Background layers ── */
  .bg-layers {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.3;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 70%);
  }

  .article {
    position: relative;
    z-index: 1;
  }

  /* ── Navigation ── */
  .article-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    max-width: 860px;
    margin: 0 auto var(--space-12);
    animation: artFadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .article-nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .article-nav-link:hover {
    color: var(--color-primary);
  }

  .article-nav-link--home {
    margin-left: auto;
    opacity: 0.6;
    font-weight: 400;
  }

  .article-nav-link--home:hover {
    opacity: 1;
  }

  /* ═══ HEADER — Editorial Masthead with subtle glass opening ═══ */
  .article-header {
    max-width: 860px;
    margin: 0 auto var(--space-18);
    padding-bottom: var(--space-14);
    border-bottom: 1px solid var(--glass-border);
    animation: artFadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }

  .article-header-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .article-header-archive {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-primary-subtle);
    border: 1px solid rgba(75, 163, 242, 0.15);
    border-radius: var(--radius-full);
    padding: 2px 10px 2px 8px;
  }

  .archive-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .archive-value {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text-tertiary);
  }

  .meta-sep {
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: var(--color-text-tertiary);
    opacity: 0.3;
  }

  .meta-item {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.58fr);
    gap: var(--space-10);
    align-items: end;
    margin-bottom: var(--space-8);
  }

  .article-hero-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .article-hero-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg-subtle);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 3.65rem;
    font-weight: 700;
    font-variation-settings: 'SOFT' 50;
    letter-spacing: -0.01em;
    line-height: 1.12;
    color: var(--color-text-primary);
    max-width: 14ch;
  }

  .article-title-brand {
    display: block;
    font-size: 1.05em;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-1);
    background: linear-gradient(120deg, var(--color-primary), #99d6ff, var(--color-primary-deep), #a78bfa);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: brandShimmer 5s ease-in-out infinite;
  }

  @keyframes brandShimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .title-sep {
    display: none;
  }

  .article-title-desc {
    display: block;
    font-size: 0.65em;
    font-weight: 500;
    color: var(--color-text-tertiary);
    line-height: 1.3;
    letter-spacing: var(--tracking-normal);
    max-width: 36ch;
    font-variation-settings: 'SOFT' 70;
  }

  .article-desc {
    font-size: var(--text-lg);
    line-height: 1.72;
    color: var(--color-text-secondary);
    font-weight: 400;
    max-width: 420px;
    padding-left: var(--space-6);
    border-left: 1px solid var(--glass-border);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1-5);
  }

  .article-tag {
    display: inline-flex;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    color: var(--color-text-tertiary);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--glass-border);
    text-transform: lowercase;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .article-tag:hover {
    color: var(--color-primary);
    background: var(--color-primary-subtle);
    border-color: rgba(75, 163, 242, 0.2);
  }

  /* ═══ BODY — Editorial Typography with Hierarchy ═══ */
  .article-body {
    max-width: 800px;
    margin: 0 auto;
    font-family: var(--font-docs);
    font-size: 1.125rem;
    line-height: 1.82;
    color: var(--color-text-secondary);
    animation: artFadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
  }

  /* MDX descendants are styled in the global block below. */

  /* ═══ FOOTER — Editorial Signature ═══ */
  .article-footer {
    max-width: 800px;
    margin: var(--space-18) auto 0;
    animation: artFadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;
  }

  .article-footer-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--glass-border), transparent);
    margin-bottom: var(--space-8);
  }

  .article-footer-signature {
    position: relative;
    padding: var(--space-6) var(--space-7);
    margin-bottom: var(--space-8);
    background: var(--glass-bg-subtle);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
  }

  .signature-line {
    position: absolute;
    top: 0;
    left: var(--space-7);
    width: 48px;
    height: 3px;
    background: var(--color-primary);
    border-radius: 0 0 2px 2px;
  }

  .signature-text {
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-tertiary);
    max-width: 68ch;
    margin-bottom: var(--space-4);
  }

  .signature-text strong {
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  .signature-author {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .signature-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    font-variation-settings: 'SOFT' 50;
    color: var(--color-text-primary);
  }

  .signature-role {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    opacity: 0.6;
  }

  .article-footer-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--glass-border);
  }

  .article-footer-nav .article-nav-link--home {
    margin-left: auto;
    opacity: 0.6;
    font-weight: 400;
  }

  .article-footer-nav .article-nav-link--home:hover {
    opacity: 1;
  }

  .article-footer .article-nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .article-footer .article-nav-link:hover {
    color: var(--color-primary);
  }

  /* ═══ RELATED ARTICLES SECTION ═══ */
  .related-section {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: var(--space-16) auto 0;
    animation: artFadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
  }

  .related-header {
    margin-bottom: var(--space-8);
  }

  .related-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-variation-settings: 'SOFT' 50;
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }

  .related-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .related-entry {
    opacity: 0;
    transform: translateY(16px);
    animation: artEntryIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    height: 100%;
  }

  /* ═══ KEYFRAMES ═══ */
  @keyframes artFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes artEntryIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ═══ LIGHT MODE ═══ */
  [data-theme="light"] .article-tag {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.08);
  }

  [data-theme="light"] .article-tag:hover {
    background: rgba(75, 163, 242, 0.08);
    border-color: rgba(75, 163, 242, 0.2);
  }

  [data-theme="light"] .article-header {
    border-bottom-color: rgba(0, 0, 0, 0.12);
  }

  [data-theme="light"] .article-header-archive {
    background: rgba(75, 163, 242, 0.08);
    border-color: rgba(75, 163, 242, 0.15);
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 768px) {
    .article-page {
      padding: 96px var(--space-4) var(--space-14);
    }

    .article-header {
      max-width: 100%;
      margin-bottom: var(--space-14);
      padding-bottom: var(--space-10);
    }

    .article-body {
      max-width: 100%;
    }

    .article-nav {
      max-width: 100%;
    }

    .article-footer {
      max-width: 100%;
    }

    .article-title {
      font-size: 2.45rem;
      line-height: 1.1;
      max-width: 100%;
    }

    .article-title-brand {
      font-size: 1em;
      margin-bottom: 0;
    }

    .article-title-desc {
      font-size: 0.7em;
      display: inline;
      color: var(--color-text-tertiary);
    }

    .title-sep {
      display: inline;
      color: var(--color-text-tertiary);
      opacity: 0.3;
      margin: 0 var(--space-2);
    }

    .article-hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
      margin-bottom: var(--space-7);
    }

    .article-hero-thumb {
      display: none;
    }

    .article-desc {
      font-size: var(--text-base);
      line-height: 1.7;
      max-width: 100%;
      padding-left: 0;
      border-left: none;
    }

    .signature-text {
      max-width: 100%;
    }

    .related-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .article-header-meta {
      font-size: 0.6rem;
    }

    .article-body {
      font-size: 1rem;
      max-width: 100%;
    }

    .article-nav {
      max-width: 100%;
    }

    .article-footer {
      max-width: 100%;
    }

    .related-section {
      max-width: 100%;
      margin-top: var(--space-12);
    }
  }
</style>

<style is:global>
  /* ═══════════════════════════════════════════════════════
     MDX ARTICLE TYPOGRAPHY
     Content rendered through <Content /> is outside Astro's scoped CSS,
     so article-body descendants must be global.
     ═══════════════════════════════════════════════════════ */

  .article-body > * {
    margin: 0;
  }

  .article-body > *:first-child {
    margin-top: 0;
  }

  .article-body > h2 {
    margin-top: var(--space-20);
  }

  .article-body > h3 {
    margin-top: var(--space-12);
  }

  .article-body > h2 + h3 {
    margin-top: var(--space-8);
  }

  .article-body > p {
    margin-top: var(--space-6);
  }

  .article-body > h3 + p {
    margin-top: var(--space-3);
  }

  .article-body > h2 + p {
    margin-top: var(--space-6);
  }

  .article-body > ul,
  .article-body > ol,
  .article-body > blockquote,
  .article-body > .callout,
  .article-body > .verdict-intro,
  .article-body > .verdict-grid,
  .article-body > div,
  .article-body > pre,
  .article-body > hr,
  .article-body > table {
    margin-top: var(--space-8);
  }

  .article-body > img,
  .article-body > .ss-frame,
  .article-body > figure:not(.screenshot-frame) {
    margin-top: var(--space-10);
  }

  .article-body > p:first-of-type {
    font-size: var(--text-xl);
    line-height: 1.8;
    color: var(--color-text-primary);
    margin-top: 0;
  }

  .article-body h2 {
    font-family: var(--font-display);
    font-size: 2.15rem;
    font-weight: 700;
    font-variation-settings: 'SOFT' 50;
    color: var(--color-text-primary);
    letter-spacing: 0;
    padding-top: var(--space-7);
    border-top: 1px solid var(--glass-border);
    line-height: 1.12;
  }

  .article-body h3 {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0;
    line-height: 1.22;
  }

  .article-body p {
    line-height: 1.82;
  }

  .article-body ul,
  .article-body ol {
    padding-left: 0;
    list-style: none;
  }

  .article-body li {
    position: relative;
    margin-top: var(--space-3);
    padding-left: var(--space-7);
    line-height: 1.75;
  }

  .article-body ul > li::before {
    content: "";
    position: absolute;
    top: 0.82em;
    left: var(--space-2);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-subtle);
  }

  .article-body ol {
    counter-reset: article-list;
  }

  .article-body ol > li {
    counter-increment: article-list;
  }

  .article-body ol > li::before {
    content: counter(article-list);
    position: absolute;
    top: 0.2em;
    left: 0;
    width: var(--space-5);
    height: var(--space-5);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .article-body li:first-child {
    margin-top: 0;
  }

  .article-body li > ul,
  .article-body li > ol {
    padding-left: var(--space-6);
    margin-top: var(--space-2);
  }

  .article-body strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .article-body a {
    color: var(--color-primary-hover);
    text-decoration: underline;
    text-decoration-color: var(--color-primary-subtle);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color var(--transition-fast), text-decoration-color var(--transition-fast);
  }

  .article-body a:hover {
    color: var(--color-primary);
    text-decoration-color: var(--color-primary);
  }

  .article-body em {
    font-style: italic;
    color: var(--color-text-primary);
    opacity: 0.92;
  }

  .article-body p code,
  .article-body li code {
    line-height: 1.4;
  }

  .article-body code {
    font-size: 0.85em;
