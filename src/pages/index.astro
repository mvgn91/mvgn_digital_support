            <div class="plan-card-badge">Cobertura</div>
            <div class="plan-card-price">
              <span class="plan-amount">$600</span>
              <span class="plan-currency">MXN</span>
            </div>
            <p class="plan-card-sub">Respaldo continuo · 6 meses</p>

            <ul class="plan-card-list">
              <li><CircleCheck size={14} /> Todo lo de Compilación</li>
              <li class="plan-card-list-divider" aria-hidden="true"></li>
              <li><Shield size={14} /> Soporte por WhatsApp</li>
              <li><Shield size={14} /> Nuevos builds ante cambios en las fuentes</li>
              <li><Shield size={14} /> Migración a método alternativo si es necesario</li>
              <li><Shield size={14} /> Canales de TV <span class="plan-card-tag">disponibilidad</span></li>
              <li><Shield size={14} /> Dashboard de estado del servicio <span class="plan-card-tag plan-card-tag--dev">En desarrollo</span></li>
