  .hero-text > .animate-in:nth-child(1) { transition-delay: 0ms; }
  .hero-text > .animate-in:nth-child(2) { transition-delay: 160ms; }
  .hero-text > .animate-in:nth-child(3) { transition-delay: 280ms; }
