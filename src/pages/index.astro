            <div class="exp-card-block">
              <h4 class="exp-card-label">Incluye</h4>
              <ul class="exp-card-list exp-card-list--inline">
                <li><CircleCheck size={14} /> Implementación inicial</li>
                <li><CircleCheck size={14} /> Configuración optimizada</li>
                <li><CircleCheck size={14} /> Centro de Soporte Digital</li>
                <li><CircleCheck size={14} /> Guías y recursos</li>
                <li><CircleCheck size={14} /> Asesoría de uso</li>
                <li><CircleCheck size={14} /> Soporte opcional</li>
              </ul>
            </div>

            <div class="exp-card-block">
              <h4 class="exp-card-label">Ideal para</h4>
