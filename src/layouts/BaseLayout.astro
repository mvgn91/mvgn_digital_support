---
// ══════════════════════════════════════════════════════════════
// MVGN Labs — Base Layout
// ══════════════════════════════════════════════════════════════

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  topbarTag?: string;
  showWhatsApp?: boolean;
}

const { title, description = 'MVGN Digital Hub — Curaduría digital, guías prácticas y soporte técnico. Un laboratorio editorial de herramientas digitales.', ogImage, topbarTag = 'MVGN DIGITAL HUB', showWhatsApp = false } = Astro.props;

// Import styles so Astro bundles them
import '../styles/global.css';
import '../styles/tokens.css';
import MessageCircle from '@lucide/astro/icons/message-circle';
---

<!DOCTYPE html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Inter font (UI) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />

    <!-- Fraunces (Display) -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700;9..144,800,50&display=swap" rel="stylesheet" />

    <!-- IBM Plex Sans (Documentación) -->
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Canonical -->
    <link rel="canonical" href={`https://mvgnlabs.vercel.app${Astro.url.pathname}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" sizes="16x16 32x32" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicon.png" sizes="180x180" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0A0A0A" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#F5F5F5" media="(prefers-color-scheme: light)" />

    <!-- Theme -->
    <meta name="color-scheme" content="dark light" />

    <title>{title} — MVGN Labs</title>

    <!-- Global Styles are imported in frontmatter and bundled by Astro -->

    <slot name="head" />
  </head>
  <body>
    <nav class="topbar">
      <div class="topbar-inner">
        <div class="topbar-brand">
          <a href="/" class="topbar-logo-link">
            <img src="/favicon.png" alt="MVGN Labs" class="topbar-logo-img" />
            <span class="topbar-name">MVGN Labs</span>
          </a>
          <span class="topbar-sep"></span>
          <span class="topbar-tag">{topbarTag}</span>
        </div>
        <div class="topbar-actions">
          <slot name="topbar-actions" />
          <button class="docs-theme-btn" id="base-theme-btn" aria-label="Cambiar tema">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="docs-theme-icon docs-theme-icon--sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="docs-theme-icon docs-theme-icon--moon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      <div class="site-footer-bg" aria-hidden="true"></div>
      <div class="site-footer-border" aria-hidden="true"></div>
      <div class="site-footer-glass" aria-hidden="true"></div>
      <div class="site-footer-inner">
        <div class="site-footer-top-row">
          <div class="site-footer-brand">
            <img src="/favicon.png" alt="" class="site-footer-logo" />
            <div>
              <span class="site-footer-name">MVGN Labs</span>
              <span class="site-footer-tagline">MVGN Digital Hub</span>
            </div>
          </div>
          <span class="site-footer-copy">&copy; {new Date().getFullYear()} MVGN Labs</span>
        </div>
        <p class="site-footer-legal">
          MVGN Labs proporciona servicios de configuración, documentación y asistencia técnica sobre aplicaciones y servicios desarrollados por terceros. MVGN Labs no es desarrollador, propietario, distribuidor oficial ni representante de las marcas o aplicaciones mencionadas.
        </p>
      </div>
    </footer>

    <!-- ═══ FLOATING ACTIONS ═══ -->
    <div class="floating-actions">
      {showWhatsApp && (
        <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="floating-btn floating-btn--wa" aria-label="WhatsApp">
          <MessageCircle size={22} />
        </a>
      )}
      <button class="floating-btn floating-btn--top" id="back-to-top" aria-label="Volver arriba">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
      </button>
    </div>
  </body>
</html>

<style is:global>
  @keyframes footer-gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes footer-glow {
    0%, 100% { opacity: 0.4; transform: translateX(-50%) scale(1); }
    50% { opacity: 0.8; transform: translateX(-50%) scale(1.1); }
  }

  /* ═══ TOPBAR ═══ */
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 52px;
    display: flex;
    align-items: center;
    padding: 0 var(--space-6);
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  .topbar-inner {
    max-width: var(--max-width-page);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .topbar-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .topbar-logo-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    overflow: hidden;
  }

  .topbar-logo-img {
    width: 20px;
    height: 20px;
    display: block;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .topbar-name {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    white-space: nowrap;
    max-width: 0;
    opacity: 0;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .topbar-logo-link:hover .topbar-name {
    max-width: 100px;
    opacity: 1;
  }

  .topbar-sep {
    width: 1px;
    height: 14px;
    background: rgba(255, 255, 255, 0.06);
  }

  .topbar-tag {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 400;
  }

  .topbar-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .topbar-back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1-5);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
  }

  .topbar-back:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  [data-theme="light"] .topbar-back:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .docs-theme-btn {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--glass-bg);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .docs-theme-btn:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.06);
  }

  .docs-theme-icon {
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  [data-theme="dark"] .docs-theme-icon--sun { display: block; }
  [data-theme="dark"] .docs-theme-icon--moon { display: none; }

  [data-theme="light"] .docs-theme-icon--sun { display: none; }
  [data-theme="light"] .docs-theme-icon--moon { display: block; }

  [data-theme="light"] .topbar {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  [data-theme="light"] .topbar-sep {
    background: rgba(0, 0, 0, 0.08);
  }

  [data-theme="light"] .docs-theme-btn {
    border-color: rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.04);
  }

  [data-theme="light"] .docs-theme-btn:hover {
    background: rgba(0, 0, 0, 0.08);
    color: var(--color-text-primary);
  }

  .site-footer {
    position: relative;
    z-index: 1;
    margin-top: var(--space-12);
    overflow: hidden;
  }

  /* Glass background */
  .site-footer-glass {
    position: absolute;
    inset: 0;
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--glass-border);
    pointer-events: none;
  }

  /* Animated gradient border on top */
  .site-footer-border {
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(75, 163, 242, 0.3), rgba(75, 163, 242, 0.5), rgba(75, 163, 242, 0.3), transparent);
    background-size: 200% 100%;
    animation: footer-gradient 8s ease-in-out infinite;
    pointer-events: none;
  }

  /* Subtle glow above the border */
  .site-footer-bg {
    position: absolute;
    top: -40px;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 80px;
    background: radial-gradient(ellipse, rgba(75, 163, 242, 0.08) 0%, transparent 70%);
    filter: blur(40px);
    animation: footer-glow 6s ease-in-out infinite;
    pointer-events: none;
  }

  .site-footer-inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-width-page);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .site-footer-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .site-footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .site-footer-brand div {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .site-footer-logo {
    width: 20px;
    height: 20px;
    border-radius: 5px;
    display: block;
  }

  .site-footer-name {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .site-footer-tagline {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .site-footer-legal {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    opacity: 0.35;
    line-height: var(--leading-relaxed);
    max-width: 640px;
    margin: 0;
  }

  .site-footer-copy {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    opacity: 0.3;
    white-space: nowrap;
  }

  [data-theme="light"] .site-footer-legal {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  [data-theme="light"] .site-footer-copy {
    color: var(--color-text-secondary);
    opacity: 0.5;
  }

  /* ══════════════════════════════════════════════════
     FLOATING ACTIONS — Back to Top & WhatsApp
     ══════════════════════════════════════════════════ */
  .floating-actions {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-8);
    z-index: 200;
    display: flex;
    flex-direction: column-reverse;
    gap: var(--space-3);
    align-items: center;
  }

  .floating-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--transition-base);
    position: relative;
  }

  .floating-btn--wa {
    background: rgba(16, 185, 129, 0.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(16, 185, 129, 0.08);
    color: var(--color-green);
  }

  .floating-btn--wa:hover {
    background: rgba(16, 185, 129, 0.15);
    transform: translateY(-1px);
  }

  .floating-btn--top {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.03);
    color: var(--color-text-tertiary);
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: all var(--transition-base);
    width: 40px;
    height: 40px;
  }

  .floating-btn--top.visible {
    opacity: 0.5;
    transform: translateY(0);
    pointer-events: auto;
  }

  .floating-btn--top:hover {
    opacity: 1;
    color: var(--color-text-primary);
    transform: translateY(-2px);
  }

  @media (max-width: 1023px) {
    .floating-actions {
      bottom: calc(52px + var(--space-6));
      right: var(--space-4);
    }

    .floating-btn {
      width: 44px;
      height: 44px;
    }
  }

  @media (max-width: 767px) {
    .floating-btn {
      width: 40px;
      height: 40px;
    }

    .topbar {
      left: var(--space-4);
      right: var(--space-4);
      width: auto;
      border-radius: var(--radius-xl);
      padding: 0 var(--space-4);
    }

    .topbar-inner {
      max-width: 100%;
    }

    .topbar-tag {
      font-size: 0.65rem;
    }

    .topbar-back span {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .site-footer-inner {
      padding: var(--space-6) var(--space-4);
      gap: var(--space-3);
    }

    .site-footer-top-row {
      flex-direction: column;
      text-align: center;
    }

    .site-footer-legal {
      font-size: 0.65rem;
      max-width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .site-footer-inner {
      padding: var(--space-5) var(--space-3);
    }

    .site-footer-legal {
      font-size: 0.6rem;
      line-height: var(--leading-normal);
    }
  }
</style>

<script is:inline>
  (function() {
    const stored = localStorage.getItem('mvgn-theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = stored || (prefersDark ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>

<script>
  (function() {
    const themeBtn = document.getElementById('base-theme-btn');
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('mvgn-theme', next);
        const themeColor = document.querySelector('meta[name="theme-color"]');
        if (themeColor) {
          themeColor.setAttribute('content', next === 'dark' ? '#0A0A0A' : '#F5F5F5');
        }
      });
    }

    const backBtn = document.getElementById('back-to-top');
    if (backBtn) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 600) {
          backBtn.classList.add('visible');
        } else {
          backBtn.classList.remove('visible');
        }
      });
      backBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  })();
</script>
