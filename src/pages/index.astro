            <span class="process-grid-title">Apoyar</span>
            <span class="process-grid-verb">Acompañar paso a paso</span>
          </div>
        </div>
      </div>

      <!-- ── Process description ── -->
      <div class="process-desc-box animate-in" id="process-desc-box">
        <p id="process-desc-text">Investigamos el panorama. Encontramos lo que existe y lo que realmente funciona.</p>
      </div>
    </section>

    <!-- ═══ MOVIMIENTO III: EL LABORATORIO ═══ -->
    <section class="section section-lab" id="laboratorio" style="scroll-margin-top: 110px;">
      <div class="section-header animate-in">
        <span class="section-tag">ID: MVGN-HUB-003 · ARCHIVO: Laboratorio</span>
        <h2 class="section-title">El <span class="title-accent">laboratorio</span></h2>
        <p class="section-desc">
          Reseñas honestas, guías prácticas y tips de uso directo del taller. Cada herramienta que publicamos pasó meses de uso real antes de llegar acá.
        </p>
      </div>

      <div class="lab-grid">
        {ultimosArticulos.map((article, i) => (
          <div class="animate-in" style={`transition-delay: ${i * 120}ms`}>
            <ArticuloCard article={article} />
          </div>
        ))}
      </div>

      <div class="lab-cta animate-in" style="transition-delay: 360ms">
        <a href="/laboratorio/" class="lab-card-link">
