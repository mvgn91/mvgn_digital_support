---
// ══════════════════════════════════════════════════════════════
// MVGN Labs — SupportCard Component
// ══════════════════════════════════════════════════════════════

import MessageCircle from '@lucide/astro/icons/message-circle';
import Mail from '@lucide/astro/icons/mail';
import Globe from '@lucide/astro/icons/globe';

export interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={{
  'support-card': true,
  'support-card--compact': compact,
}}>
  <h3 class="support-title">¿Necesitas ayuda?</h3>
  {!compact && <p class="support-desc">Estamos aquí para asistirte en cada paso.</p>}
  <div class="support-channels">
    <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="support-channel">
      <span class="channel-icon">
        <MessageCircle size={20} />
      </span>
      <div class="channel-info">
        <span class="channel-label">WhatsApp</span>
        <span class="channel-value">33 2262 1939</span>
      </div>
    </a>

    <a href="mailto:mvgnlabs@proton.me" class="support-channel">
      <span class="channel-icon">
        <Mail size={20} />
      </span>
      <div class="channel-info">
        <span class="channel-label">Correo</span>
        <span class="channel-value">mvgnlabs@proton.me</span>
      </div>
    </a>

    <a href="https://mvgn.vercel.app" target="_blank" rel="noopener noreferrer" class="support-channel">
      <span class="channel-icon">
        <Globe size={20} />
      </span>
      <div class="channel-info">
        <span class="channel-label">Sitio web</span>
        <span class="channel-value">mvgn.vercel.app</span>
      </div>
    </a>
  </div>
</div>

<style is:global>
  .support-card {
    background: var(--glass-bg);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .support-card--compact {
    padding: var(--space-4);
  }

  .support-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .support-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .support-channels {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .support-channel {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .support-channel:hover {
    border-color: rgba(220, 38, 38, 0.15);
    background: rgba(220, 38, 38, 0.04);
  }

  .channel-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
    background: rgba(220, 38, 38, 0.06);
    border: 1px solid rgba(220, 38, 38, 0.1);
  }

  .support-channel:hover .channel-icon {
    background: rgba(220, 38, 38, 0.12);
    border-color: rgba(220, 38, 38, 0.2);
  }

  .channel-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .channel-label {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .channel-value {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .support-card--compact .support-title {
    font-size: var(--text-lg);
  }

  .support-card--compact .support-channel {
    padding: var(--space-2) var(--space-3);
  }
  @media (max-width: 640px) {
    .support-card {
      padding: var(--space-5);
    }

    .support-title {
      font-size: var(--text-lg);
    }

    .support-channel {
      padding: var(--space-2-5) var(--space-3);
    }

    .channel-icon {
      width: 32px;
      height: 32px;
    }

    .channel-icon svg {
      width: 18px;
      height: 18px;
    }

    .channel-label {
      font-size: 0.65rem;
    }

    .channel-value {
      font-size: var(--text-xs);
    }
  }
</style>
