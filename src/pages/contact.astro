---
// ══════════════════════════════════════════════════════════════
// MVGN Labs — Contact Page (v2)
// Rediseño completo — sin sidebar, sin ContactCard
// ══════════════════════════════════════════════════════════════

import BaseLayout from '../layouts/BaseLayout.astro';
import MessageCircle from '@lucide/astro/icons/message-circle';
import Mail from '@lucide/astro/icons/mail';
import CircleQuestionMark from '@lucide/astro/icons/circle-question-mark';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Clock from '@lucide/astro/icons/clock';
import Zap from '@lucide/astro/icons/zap';
import CircleCheck from '@lucide/astro/icons/circle-check';
---

<BaseLayout title="Contacto — MVGN Labs" description="Estamos aquí para ayudarte. Contáctanos por WhatsApp o correo electrónico." topbarTag="CENTRO DE SOPORTE">
  <a href="/" slot="topbar-actions" class="topbar-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    <span>Volver</span>
  </a>
  <div class="contact-page">

    <!-- ═══ AMBIENT BACKGROUND ═══ -->
    <div class="contact-bg" aria-hidden="true">
      <div class="contact-bg-ambient"></div>
      <div class="contact-bg-glow"></div>
      <div class="contact-bg-orbs">
        <div class="contact-orb contact-orb--1"></div>
        <div class="contact-orb contact-orb--2"></div>
        <div class="contact-orb contact-orb--3"></div>
      </div>
      <div class="contact-bg-grid"></div>
    </div>

    <!-- ═══ HERO ═══ -->
    <header class="contact-hero">
      <div class="contact-hero-inner">
        <div class="contact-hero-badge animate-once">
          <span class="contact-hero-dot"></span>
          Contacto Directo
        </div>

        <h1 class="contact-hero-title animate-once">
          Contacto y Soporte Técnico
        </h1>

        <p class="contact-hero-desc animate-once">
          MVGN Labs ofrece canales directos de atención para consultas técnicas, 
          configuración de servicios y asistencia especializada.
        </p>
      </div>

      <!-- Scroll indicator -->
      <div class="contact-scroll-hint" aria-hidden="true">
        <div class="contact-scroll-mouse">
          <div class="contact-scroll-wheel"></div>
        </div>
        <span>Desplázate</span>
      </div>
    </header>

    <!-- ═══ CHANNELS GRID ═══ -->
    <section class="contact-channels">
      <div class="contact-channels-inner">

        <!-- WhatsApp -->
        <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="channel-card channel-card--wa animate-on-scroll">
          <div class="channel-card-bg"></div>
          <div class="channel-card-accent"></div>
          <div class="channel-card-content">
            <div class="channel-card-icon-wrap">
              <MessageCircle size={26} />
            </div>
            <div class="channel-card-body">
              <h2 class="channel-card-title">WhatsApp</h2>
              <p class="channel-card-desc">
                Canal prioritario con el tiempo de respuesta más ágil. Se atiende en un promedio de <strong>30 minutos</strong>.
              </p>
              <span class="channel-card-meta">+52 33 2262 1939</span>
            </div>
            <div class="channel-card-arrow">
              <ArrowRight size={18} />
            </div>
          </div>
        </a>

        <!-- Email -->
        <a href="mailto:mvgnlabs@proton.me" class="channel-card channel-card--email animate-on-scroll">
          <div class="channel-card-bg"></div>
          <div class="channel-card-accent"></div>
          <div class="channel-card-content">
            <div class="channel-card-icon-wrap">
              <Mail size={26} />
            </div>
            <div class="channel-card-body">
              <h2 class="channel-card-title">Correo Electrónico</h2>
              <p class="channel-card-desc">
                Para solicitudes formales y documentación detallada. Se responde en un plazo máximo de <strong>2 horas</strong>.
              </p>
              <span class="channel-card-meta">mvgnlabs@proton.me</span>
            </div>
            <div class="channel-card-arrow">
              <ArrowRight size={18} />
            </div>
          </div>
        </a>

        <!-- FAQ -->
        <a href="/faq" class="channel-card channel-card--faq animate-on-scroll">
          <div class="channel-card-bg"></div>
          <div class="channel-card-accent"></div>
          <div class="channel-card-content">
            <div class="channel-card-icon-wrap">
              <CircleQuestionMark size={26} />
            </div>
            <div class="channel-card-body">
              <h2 class="channel-card-title">Preguntas Frecuentes</h2>
              <p class="channel-card-desc">
                Consulte el centro de ayuda antes de contactar. Es posible que su consulta ya esté resuelta.
              </p>
              <span class="channel-card-meta">Centro de ayuda</span>
            </div>
            <div class="channel-card-arrow">
              <ArrowRight size={18} />
            </div>
          </div>
        </a>

      </div>
    </section>

    <!-- ═══ INFO GRID ═══ -->
    <section class="contact-info">
      <div class="contact-info-inner">

        <!-- Hours -->
        <div class="info-card animate-on-scroll">
          <div class="info-card-header">
            <span class="info-card-icon"><Clock size={18} /></span>
            <h3 class="info-card-title">Horario de Atención</h3>
          </div>
          <div class="info-card-body">
            <div class="schedule-row schedule-row--active">
              <span class="schedule-day">Lunes — Sábado</span>
              <span class="schedule-time">9:00 — 20:00</span>
              <span class="schedule-badge">Activo</span>
            </div>
            <div class="schedule-row">
              <span class="schedule-day">Domingo</span>
              <span class="schedule-time">10:00 — 16:00</span>
              <span class="schedule-badge schedule-badge--dim">Reducido</span>
            </div>
          </div>
        </div>

        <!-- Response Times -->
        <div class="info-card animate-on-scroll">
          <div class="info-card-header">
            <span class="info-card-icon"><Zap size={18} /></span>
            <h3 class="info-card-title">Tiempos de Respuesta</h3>
          </div>
          <div class="info-card-body">
            <div class="response-row">
              <div class="response-visual">
                <div class="response-bar response-bar--full"></div>
              </div>
              <div class="response-body">
                <span class="response-label">WhatsApp</span>
                <span class="response-value">&lt; 30 min</span>
              </div>
            </div>
            <div class="response-row">
              <div class="response-visual">
                <div class="response-bar response-bar--mid"></div>
              </div>
              <div class="response-body">
                <span class="response-label">Correo</span>
                <span class="response-value">&lt; 2 horas</span>
              </div>
            </div>
            <div class="response-row">
              <div class="response-visual">
                <div class="response-bar response-bar--instant"></div>
              </div>
              <div class="response-body">
                <span class="response-label">FAQ</span>
                <span class="response-value">Instantáneo</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Status -->
        <div class="info-card info-card--status animate-on-scroll">
          <div class="info-card-header">
            <span class="info-card-icon"><CircleCheck size={18} /></span>
            <h3 class="info-card-title">Estado del Soporte</h3>
          </div>
          <div class="info-card-body">
            <div class="status-banner">
              <div class="status-banner-dot"></div>
              <div class="status-banner-body">
                <strong>Disponibilidad inmediata</strong>
                <p>El equipo de soporte se encuentra disponible para recibir y atender consultas técnicas.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══ BOTTOM CTA ═══ -->
    <section class="contact-cta animate-on-scroll">
      <div class="contact-cta-glow" aria-hidden="true"></div>
      <div class="contact-cta-inner">
        <div class="contact-cta-body">
          <h2 class="contact-cta-title">¿Requiere asistencia técnica?</h2>
          <p class="contact-cta-desc">
            Nuestro equipo está preparado para atender sus consultas y brindarle la solución que necesita.
          </p>
        </div>
        <div class="contact-cta-actions">
          <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--primary">
            <MessageCircle size={18} />
            Hablar por WhatsApp
            <ArrowRight size={18} />
          </a>
          <a href="mailto:mvgnlabs@proton.me" class="cta-btn cta-btn--ghost">
            <Mail size={18} />
            Enviar correo
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  // ── Scroll Animations ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.animate-on-scroll').forEach(el => {
      observer.observe(el);
    });
</script>

<style is:global>
  /* ══════════════════════════════════════════════════════════
     CONTACT PAGE v2 — COMPLETE REDESIGN
     ══════════════════════════════════════════════════════════ */

  /* ── Base ── */
  .contact-page {
    position: relative;
    background: var(--color-bg);
    min-height: 100vh;
    overflow: hidden;
  }

  /* ══════════════════════════════════════════════════════════
     AMBIENT BACKGROUND
     ══════════════════════════════════════════════════════════ */
  .contact-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .contact-bg-ambient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 35% at 50% 0%, rgba(220, 38, 38, 0.2) 0%, transparent 50%),
      radial-gradient(ellipse 70% 20% at 50% 100%, rgba(220, 38, 38, 0.06) 0%, transparent 50%);
  }

  [data-theme="light"] .contact-bg-ambient {
    opacity: 0.35;
  }

  .contact-bg-glow {
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: min(900px, 80vw);
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(220, 38, 38, 0.15) 0%, rgba(220, 38, 38, 0.04) 35%, transparent 60%);
    filter: blur(120px);
    animation: contact-glow-drift 20s ease-in-out infinite;
  }

  @keyframes contact-glow-drift {
    0%, 100% { transform: translateX(-50%) translateY(0) scale(1); }
    33% { transform: translateX(-50%) translateY(-2%) scale(1.05); }
    66% { transform: translateX(-50%) translateY(2%) scale(0.95); }
  }

  .contact-bg-orbs {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .contact-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.12;
  }

  .contact-orb--1 {
    top: 15%;
    right: -5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(220, 38, 38, 0.3), transparent);
    animation: orb-float 18s ease-in-out infinite;
  }

  .contact-orb--2 {
    bottom: 10%;
    left: -8%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.2), transparent);
    animation: orb-float 22s ease-in-out infinite reverse;
  }

  .contact-orb--3 {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.1), transparent);
    animation: orb-float 26s ease-in-out infinite;
  }

  @keyframes orb-float {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(3%, -2%); }
    50% { transform: translate(-2%, 3%); }
    75% { transform: translate(1%, -1%); }
  }

  .contact-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--glass-bg-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--glass-bg-subtle) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 60% 45% at 50% 0%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 45% at 50% 0%, black 20%, transparent 70%);
  }

  /* ══════════════════════════════════════════════════════════
     HERO
     ══════════════════════════════════════════════════════════ */
  .contact-hero {
    position: relative;
    z-index: 1;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 100px var(--space-6) var(--space-16);
  }

  .contact-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    max-width: 680px;
  }

  .contact-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    background: rgba(220, 38, 38, 0.08);
    color: var(--color-primary);
    border: 1px solid rgba(220, 38, 38, 0.12);
  }

  .contact-hero-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: hero-dot-pulse 2s ease-in-out infinite;
  }

  @keyframes hero-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.8); }
  }

  .contact-hero-title {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--color-text-primary);
    margin: 0;
  }

  .contact-hero-accent {
    display: block;
    background: linear-gradient(135deg, var(--color-primary) 0%, #ef4444 50%, #f87171 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: accent-shimmer 8s ease-in-out infinite;
  }

  @keyframes accent-shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .contact-hero-desc {
    font-size: var(--text-lg);
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
    max-width: 540px;
    margin: 0;
  }

  /* ── Scroll Hint ── */
  .contact-scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    opacity: 0.25;
    animation: scroll-hint-fade 3s ease-in-out infinite;
  }

  .contact-scroll-mouse {
    width: 22px;
    height: 34px;
    border-radius: 12px;
    border: 2px solid var(--color-text-tertiary);
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .contact-scroll-wheel {
    width: 3px;
    height: 8px;
    border-radius: 3px;
    background: var(--color-text-tertiary);
    animation: scroll-wheel 2s ease-in-out infinite;
  }

  @keyframes scroll-wheel {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(10px); opacity: 0; }
  }

  @keyframes scroll-hint-fade {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.35; }
  }

  .contact-scroll-hint span {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  /* ══════════════════════════════════════════════════════════
     CHANNELS SECTION
     ══════════════════════════════════════════════════════════ */
  .contact-channels {
    position: relative;
    z-index: 1;
    padding: 0 var(--space-6) var(--space-10);
  }

  .contact-channels-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ── Channel Card ── */
  .channel-card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    isolation: isolate;
  }

  .channel-card:hover {
    transform: translateY(-3px);
  }

  /* Card Background */
  .channel-card-bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: -1;
    transition: all 0.4s ease;
  }

  .channel-card--wa .channel-card-bg {
    background: linear-gradient(145deg,
      rgba(16, 185, 129, 0.06) 0%,
      rgba(255, 255, 255, 0.02) 40%,
      var(--glass-bg) 70%
    );
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid rgba(16, 185, 129, 0.1);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .channel-card--wa:hover .channel-card-bg {
    border-color: rgba(16, 185, 129, 0.2);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.3), 0 0 60px rgba(16, 185, 129, 0.04);
  }

  .channel-card--email .channel-card-bg {
    background: linear-gradient(145deg,
      rgba(59, 130, 246, 0.06) 0%,
      rgba(255, 255, 255, 0.02) 40%,
      var(--glass-bg) 70%
    );
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid rgba(59, 130, 246, 0.1);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .channel-card--email:hover .channel-card-bg {
    border-color: rgba(59, 130, 246, 0.2);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.3), 0 0 60px rgba(59, 130, 246, 0.04);
  }

  .channel-card--faq .channel-card-bg {
    background: linear-gradient(145deg,
      rgba(168, 85, 247, 0.06) 0%,
      rgba(255, 255, 255, 0.02) 40%,
      var(--glass-bg) 70%
    );
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid rgba(168, 85, 247, 0.1);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .channel-card--faq:hover .channel-card-bg {
    border-color: rgba(168, 85, 247, 0.2);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.3), 0 0 60px rgba(168, 85, 247, 0.04);
  }

  /* Accent line */
  .channel-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    border-radius: 2px 0 0 2px;
    transition: all 0.4s ease;
  }

  .channel-card--wa .channel-card-accent {
    background: linear-gradient(180deg, rgba(16, 185, 129, 0.6), rgba(16, 185, 129, 0.1));
  }

  .channel-card--wa:hover .channel-card-accent {
    background: linear-gradient(180deg, rgba(16, 185, 129, 0.9), rgba(16, 185, 129, 0.2));
  }

  .channel-card--email .channel-card-accent {
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.6), rgba(59, 130, 246, 0.1));
  }

  .channel-card--email:hover .channel-card-accent {
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.9), rgba(59, 130, 246, 0.2));
  }

  .channel-card--faq .channel-card-accent {
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.6), rgba(168, 85, 247, 0.1));
  }

  .channel-card--faq:hover .channel-card-accent {
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.9), rgba(168, 85, 247, 0.2));
  }

  /* Card Content */
  .channel-card-content {
    position: relative;
    z-index: 1;
    padding: var(--space-6) var(--space-6) var(--space-6) calc(var(--space-6) + 3px);
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .channel-card-icon-wrap {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.4s ease;
  }

  .channel-card--wa .channel-card-icon-wrap {
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-green);
  }

  .channel-card--wa:hover .channel-card-icon-wrap {
    background: rgba(16, 185, 129, 0.18);
    box-shadow: 0 0 24px rgba(16, 185, 129, 0.08);
    transform: scale(1.05);
  }

  .channel-card--email .channel-card-icon-wrap {
    background: rgba(59, 130, 246, 0.1);
    color: var(--color-info);
  }

  .channel-card--email:hover .channel-card-icon-wrap {
    background: rgba(59, 130, 246, 0.18);
    box-shadow: 0 0 24px rgba(59, 130, 246, 0.08);
    transform: scale(1.05);
  }

  .channel-card--faq .channel-card-icon-wrap {
    background: rgba(168, 85, 247, 0.1);
    color: var(--color-purple);
  }

  .channel-card--faq:hover .channel-card-icon-wrap {
    background: rgba(168, 85, 247, 0.18);
    box-shadow: 0 0 24px rgba(168, 85, 247, 0.08);
    transform: scale(1.05);
  }

  .channel-card-body {
    flex: 1;
    min-width: 0;
  }

  .channel-card-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-1);
  }

  .channel-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 42ch;
  }

  .channel-card-desc strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .channel-card-meta {
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-tertiary);
    margin-top: 6px;
    font-family: var(--font-mono);
    letter-spacing: -0.01em;
  }

