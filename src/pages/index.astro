            <ul class="plan-card-list">
              <li><CircleCheck size={14} /> Build verificado para Android TV</li>
              <li><CircleCheck size={14} /> Build verificado para Mobile / Tablet</li>
              <li><CircleCheck size={14} /> Guía PDF de instalación paso a paso</li>
            </ul>

            <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="plan-card-btn">
              Consultar disponibilidad
              <ChevronRight size={16} />
            </a>

            <p class="plan-card-note">
              Para quien solo necesita los archivos. Una sola entrega, sin compromiso recurrente.
            </p>
          </div>
        </article>

        <!-- Cobertura -->
        <article class="plan-card plan-card--active animate-in">
          <div class="plan-card-content">
            <span class="plan-card-popular">
              <Sparkles size={12} />
