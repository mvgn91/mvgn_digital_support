---
import BaseLayout from '../layouts/BaseLayout.astro';
import HellBackground from '../components/HellBackground';
import CascadeMobileScreens from '../components/CascadeMobileScreens';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import MessageCircle from '@lucide/astro/icons/message-circle';
import CircleCheck from '@lucide/astro/icons/circle-check';
import Sparkles from '@lucide/astro/icons/sparkles';
import CircleQuestionMark from '@lucide/astro/icons/circle-question-mark';
import FolderOpen from '@lucide/astro/icons/folder-open';
import Video from '@lucide/astro/icons/video';
import Smartphone from '@lucide/astro/icons/smartphone';
import Monitor from '@lucide/astro/icons/monitor';
import Settings from '@lucide/astro/icons/settings';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import Mail from '@lucide/astro/icons/mail';
import Shield from '@lucide/astro/icons/shield';

---

<BaseLayout title="MVGN Labs — Centro de Soporte Digital">
  <div class="page">

    <!-- ═══ GLOBAL BACKGROUND ═══ -->
    <div class="bg-layers" aria-hidden="true">
      <div class="bg-ambient"></div>
      <div class="bg-glow-center"></div>
      <div class="bg-glow-right"></div>
      <div class="bg-glow-left"></div>
      <div class="bg-grid"></div>
    </div>

    <!-- ═══ NAV TOP BAR ═══ -->
    <nav class="topbar">
      <div class="topbar-inner">
        <div class="topbar-brand">
          <a href="/" class="topbar-logo-link">
            <img src="/favicon.png" alt="MVGN Labs" class="topbar-logo-img" />
            <span class="topbar-name">MVGN Labs</span>
          </a>
          <span class="topbar-sep"></span>
          <span class="topbar-tag">CENTRO DE SOPORTE</span>
        </div>
        <div class="topbar-actions">
          <button class="docs-theme-btn" id="index-theme-btn" aria-label="Cambiar tema">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="docs-theme-icon docs-theme-icon--sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="docs-theme-icon docs-theme-icon--moon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- ═══ FLOATING PILL NAV ═══ -->
    <nav class="pillnav" id="pillnav" aria-label="Secciones">
      <div class="pillnav-track">
        <div class="pillnav-indicator" id="pillnav-indicator" aria-hidden="true"></div>
        <a href="#experiencias" class="pillnav-link" data-section="experiencias">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>
          <span class="pillnav-label">Soluciones</span>
        </a>
        <a href="#includes" class="pillnav-link" data-section="includes">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span class="pillnav-label">Incluye</span>
        </a>
        <a href="#como-funciona" class="pillnav-link" data-section="como-funciona">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
          <span class="pillnav-label">Cómo funciona</span>
        </a>
        <a href="#planes" class="pillnav-link" data-section="planes">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
          <span class="pillnav-label">Planes</span>
        </a>
        <a href="#filosofia" class="pillnav-link" data-section="filosofia">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          <span class="pillnav-label">Filosofía</span>
        </a>
        <a href="#contacto" class="pillnav-link" data-section="contacto">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span class="pillnav-label">Contacto</span>
        </a>
      </div>
    </nav>

    <!-- ═══ FLOATING ACTIONS ═══ -->
    <div class="floating-actions">
      <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="floating-btn floating-btn--wa" aria-label="WhatsApp">
        <MessageCircle size={22} />
      </a>
      <button class="floating-btn floating-btn--top" id="back-to-top" aria-label="Volver arriba">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
      </button>
    </div>

    <script>
      (function() {
        const sections = ['experiencias', 'includes', 'como-funciona', 'planes', 'filosofia', 'contacto'];
        const pillnav = document.getElementById('pillnav');
        const backBtn = document.getElementById('back-to-top');

        function setActive(id) {
          document.querySelectorAll('.pillnav-link').forEach(el => el.classList.remove('active'));
          const activeEl = document.querySelector(`.pillnav-link[data-section="${id}"]`);
          if (activeEl) {
            activeEl.classList.add('active');
            const indicator = document.getElementById('pillnav-indicator');
            if (indicator) {
              indicator.style.width = activeEl.offsetWidth + 'px';
              indicator.style.transform = 'translateX(' + activeEl.offsetLeft + 'px)';
            }
          }
        }

        function update() {
          const hero = document.getElementById('hero');
          const heroBottom = hero ? hero.getBoundingClientRect().bottom : 0;
          const pastHero = heroBottom < 0;

          if (pillnav) {
            if (pastHero) {
              pillnav.classList.add('visible');
            } else {
              pillnav.classList.remove('visible');
            }
          }

          if (backBtn) {
            if (pastHero) {
              backBtn.classList.add('visible');
            } else {
              backBtn.classList.remove('visible');
            }
          }

          if (pastHero) {
            let active = null;
            const threshold = window.innerHeight * 0.35;
            sections.forEach(id => {
              const el = document.getElementById(id);
              if (el) {
                const rect = el.getBoundingClientRect();
                if (rect.top <= threshold) {
                  active = id;
                }
              }
            });
            if (active) setActive(active);
          }
        }

        window.addEventListener('scroll', update, { passive: true });
        setTimeout(update, 100);

        if (backBtn) {
          backBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }

        // Theme toggle
        const themeBtn = document.getElementById('index-theme-btn');
        if (themeBtn) {
          themeBtn.addEventListener('click', () => {
            const html = document.documentElement;
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('mvgn-theme', next);
          });
        }

        // ── Entrance Animations ──
        const animObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              animObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.animate-in').forEach(el => {
          animObserver.observe(el);
        });


      })();
    </script>

    <!-- ═══ HERO — Split Console ═══ -->
    <header class="hero" id="hero">
      <div class="hero-shader-bg" aria-hidden="true">
        <HellBackground color="#B0B0B8" client:load />
      </div>
      <div class="hero-bg-glow" aria-hidden="true"></div>

      <div class="hero-split">

        <!-- ── Left: Text ── -->
        <div class="hero-text">
          <div class="hero-badge animate-in in-view">
            <span class="hero-badge-dot"></span>
            Centro de Soporte Digital
          </div>

          <h1 class="hero-title animate-in in-view">
            Menos configuración.
            <span class="hero-title-accent">Más entretenimiento.</span>
