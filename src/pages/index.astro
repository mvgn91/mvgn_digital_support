---
import BaseLayout from '../layouts/BaseLayout.astro';
import HellBackground from '../components/HellBackground';
import CascadeMobileScreens from '../components/CascadeMobileScreens';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import MessageCircle from '@lucide/astro/icons/message-circle';
import Mail from '@lucide/astro/icons/mail';
import ExternalLink from '@lucide/astro/icons/external-link';
import CircleCheck from '@lucide/astro/icons/circle-check';
import Sparkles from '@lucide/astro/icons/sparkles';

import Settings from '@lucide/astro/icons/settings';
import Shield from '@lucide/astro/icons/shield';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import CurvedLoop from '../components/CurvedLoop/CurvedLoop';
 
---

<BaseLayout title="MVGN Digital Hub — Laboratorio Editorial de Herramientas Digitales">
  <div class="page">

    <!-- ═══ GLOBAL BACKGROUND ═══ -->
    <div class="bg-layers" aria-hidden="true">
      <div class="bg-ambient"></div>
      <div class="bg-grid"></div>
    </div>

    <!-- ═══ NAV TOP BAR ═══ -->
    <nav class="topbar">
      <div class="topbar-inner">
        <div class="topbar-brand">
          <a href="/" class="topbar-logo-link">
            <img src="/favicon.png" alt="MVGN Labs" class="topbar-logo-img" />
            <span class="topbar-name">MVGN Labs</span>
          </a>
          <span class="topbar-sep"></span>
          <span class="topbar-tag">MVGN DIGITAL HUB</span>
        </div>
        <div class="topbar-actions">
          <button class="docs-theme-btn" id="index-theme-btn" aria-label="Cambiar tema">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="docs-theme-icon docs-theme-icon--sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="docs-theme-icon docs-theme-icon--moon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- ═══ FLOATING PILL NAV — macOS Tabs ═══ -->
    <nav class="pillnav" id="pillnav" aria-label="Secciones">
      <div class="pillnav-track">
        <a href="#proceso" class="pillnav-link" data-section="proceso">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span class="pillnav-label">Proceso</span>
        </a>
        <a href="#laboratorio" class="pillnav-link" data-section="laboratorio">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          <span class="pillnav-label">Laboratorio</span>
        </a>
        <a href="#planes" class="pillnav-link" data-section="planes">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
          <span class="pillnav-label">Planes</span>
        </a>
        <a href="#filosofia" class="pillnav-link" data-section="filosofia">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          <span class="pillnav-label">Filosofía</span>
        </a>
        <a href="#contacto" class="pillnav-link" data-section="contacto">
          <svg class="pillnav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span class="pillnav-label">Contacto</span>
        </a>
      </div>
    </nav>

    <!-- ═══ FLOATING ACTIONS ═══ -->
    <div class="floating-actions">
      <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="floating-btn floating-btn--wa" aria-label="WhatsApp">
        <MessageCircle size={22} />
      </a>
      <button class="floating-btn floating-btn--top" id="back-to-top" aria-label="Volver arriba">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
      </button>
    </div>

    <script>
      (function() {
        const sections = ['proceso', 'laboratorio', 'planes', 'filosofia', 'contacto'];
        const pillnav = document.getElementById('pillnav');
        const backBtn = document.getElementById('back-to-top');

        function setActive(id) {
          document.querySelectorAll('.pillnav-link').forEach(el => el.classList.remove('active'));
          const activeEl = document.querySelector(`.pillnav-link[data-section="${id}"]`);
          if (activeEl) activeEl.classList.add('active');
        }

        function update() {
          const hero = document.getElementById('hero');
          const heroBottom = hero ? hero.getBoundingClientRect().bottom : 0;
          const pastHero = heroBottom < 0;

          if (pillnav) {
            if (pastHero) {
              pillnav.classList.add('visible');
            } else {
              pillnav.classList.remove('visible');
            }
          }

          if (backBtn) {
            if (pastHero) {
              backBtn.classList.add('visible');
            } else {
              backBtn.classList.remove('visible');
            }
          }

          if (pastHero) {
            let active = null;
            const threshold = window.innerHeight * 0.35;
            sections.forEach(id => {
              const el = document.getElementById(id);
              if (el) {
                const rect = el.getBoundingClientRect();
                if (rect.top <= threshold) {
                  active = id;
                }
              }
            });
            if (active) setActive(active);
          }
        }

        window.addEventListener('scroll', update, { passive: true });
        setTimeout(update, 100);

        if (backBtn) {
          backBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }

        // Theme toggle
        const themeBtn = document.getElementById('index-theme-btn');
        if (themeBtn) {
          themeBtn.addEventListener('click', () => {
            const html = document.documentElement;
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('mvgn-theme', next);
            const themeColor = document.querySelector('meta[name="theme-color"]');
            if (themeColor) {
              themeColor.setAttribute('content', next === 'dark' ? '#0A0A0A' : '#F5F5F5');
            }
          });
        }

        // ── Entrance Animations ──
        const animObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              animObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.animate-in').forEach(el => {
          animObserver.observe(el);
        });

        // ── Process bar hover ──
        const processSteps = document.querySelectorAll('.process-step');
        const descEl = document.getElementById('process-desc-text');
        const descriptions = [
          'Investigamos el panorama. Encontramos lo que existe y lo que realmente funciona.',
          'Probamos en entorno real. Medimos estabilidad, seguridad y utilidad.',
          'Escribimos guías claras. Sin tecnicismos innecesarios. Solo lo que necesitas saber.',
          'Publicamos nuestras conclusiones. Solo lo que usaríamos nosotros mismos.',
          'Si prefieres no hacerlo tú mismo, caminamos contigo paso a paso.'
        ];

        if (processSteps.length && descEl) {
          function activateStep(step) {
            const idx = parseInt(step.dataset.step);
            descEl.textContent = descriptions[idx];
            processSteps.forEach(s => s.classList.remove('active'));
            step.classList.add('active');
          }

          function resetToFirst() {
            descEl.textContent = descriptions[0];
            processSteps.forEach(s => s.classList.remove('active'));
            processSteps[0].classList.add('active');
          }

          processSteps.forEach(step => {
            step.addEventListener('mouseenter', () => activateStep(step));
            step.addEventListener('click', (e) => {
              activateStep(step);
              e.stopPropagation();
            });
          });

          const bar = document.getElementById('process-bar');
          if (bar) {
            bar.addEventListener('mouseleave', resetToFirst);
          }

          // Reset on click outside
          document.addEventListener('click', (e) => {
            const bar = document.getElementById('process-bar');
            if (bar && !bar.contains(e.target)) {
              resetToFirst();
            }
          });

          processSteps[0].classList.add('active');
        }


      })();
    </script>

    <!-- ═══ HERO — Split Console ═══ -->
    <header class="hero" id="hero">
      <div class="hero-shader-bg" aria-hidden="true">
        <HellBackground color="#B0B0B8" client:load />
      </div>
      <div class="hero-split">

        <!-- ── Left: Text ── -->
        <div class="hero-text">
          <div class="hero-badge animate-in in-view">
            ID: MVGN-HUB-001 · ARCHIVO: Manifiesto
          </div>

          <h1 class="hero-title animate-in in-view">
            Hay demasiado software ahí afuera.
            <span class="hero-title-accent">Nosotros lo filtramos.</span>
          </h1>

          <p class="hero-sub animate-in in-view">
            Investigamos, probamos y documentamos herramientas digitales para que no tengas que hacerlo tú.
          </p>

          <div class="hero-actions animate-in in-view">
            <a href="#proceso" class="btn btn--primary">
              Conocer el laboratorio
              <ArrowRight size={18} />
            </a>
          </div>

        </div>

        <!-- ── Right: Cascading Screens ── -->
        <div class="hero-visual">
          <CascadeMobileScreens client:load images={{
            streaming: "/material%20design%20mockup%201.png",
            addon: "/material%20design%20mockup%202.png",
            blog: "/material%20design%20mockup%203.png",
          }} />
        </div>

      </div>
    </header>

    

    <!-- ═══ MANIFIESTO QUOTE + MÉTRICAS ═══ -->
    <section class="section section-manifesto" id="manifiesto">
      <div class="manifesto-content">

        <!-- ── Dynamic background glow ── -->
        <div class="manifesto-glow" aria-hidden="true"></div>

        <!-- ── Pull-quote ── -->
        <blockquote class="manifesto-pullquote animate-in">
          <div class="manifesto-pullquote-accent" aria-hidden="true"></div>
          <div class="manifesto-pullquote-body">
            <span class="manifesto-pullquote-mark" aria-hidden="true">&ldquo;</span>
            <p>
              No recomendamos herramientas porque sean nuevas.<br>
              Las recomendamos porque siguen instaladas en nuestros propios equipos.
            </p>
          </div>
        </blockquote>

        <!-- ── Stats grid ── -->
        <div class="manifesto-stats animate-in">
          <div class="manifesto-stat-card">
            <span class="manifesto-stat-num">24</span>
            <span class="manifesto-stat-label">Herramientas documentadas</span>
          </div>
          <div class="manifesto-stat-card">
            <span class="manifesto-stat-num">18</span>
            <span class="manifesto-stat-label">Guías publicadas</span>
          </div>
          <div class="manifesto-stat-card">
            <span class="manifesto-stat-num">9</span>
            <span class="manifesto-stat-label">En evaluación</span>
          </div>
          <div class="manifesto-stat-card">
            <span class="manifesto-stat-num">17</span>
            <span class="manifesto-stat-label">Recomendadas</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══ MOVIMIENTO II: CÓMO TRABAJAMOS ═══ -->
    <section class="section section-timeline" id="proceso" style="scroll-margin-top: 110px;">
      <div class="section-header animate-in">
        <span class="section-tag">ID: MVGN-HUB-002 · ARCHIVO: Metodología</span>
        <h2 class="section-title">Nuestro <span class="title-accent">proceso</span></h2>
        <p class="section-desc">
          No vendemos herramientas. Las investigamos.
        </p>
      </div>

      <!-- ── Process bar — horizontal ── -->
      <div class="process-bar animate-in" id="process-bar">
        <div class="process-step" data-step="0">
          <span class="process-step-num">01</span>
          <span class="process-step-title">Descubrir</span>
        </div>
        <div class="process-step" data-step="1">
          <span class="process-step-num">02</span>
          <span class="process-step-title">Evaluar</span>
        </div>
        <div class="process-step" data-step="2">
          <span class="process-step-num">03</span>
          <span class="process-step-title">Documentar</span>
        </div>
        <div class="process-step" data-step="3">
          <span class="process-step-num">04</span>
          <span class="process-step-title">Recomendar</span>
        </div>
        <div class="process-step" data-step="4">
          <span class="process-step-num">05</span>
          <span class="process-step-title">Apoyar</span>
        </div>
      </div>

      <!-- ── Process description ── -->
      <div class="process-desc-box animate-in" id="process-desc-box">
        <p id="process-desc-text">Investigamos el panorama. Encontramos lo que existe y lo que realmente funciona.</p>
      </div>
    </section>

    <!-- ═══ MOVIMIENTO III: EL LABORATORIO ═══ -->
    <section class="section section-lab" id="laboratorio" style="scroll-margin-top: 110px;">
      <div class="section-header animate-in">
        <span class="section-tag">ID: MVGN-HUB-003 · ARCHIVO: Laboratorio</span>
        <h2 class="section-title">El <span class="title-accent">laboratorio</span></h2>
        <p class="section-desc">
          Tres áreas de trabajo continuo. Herramientas reales, guías prácticas, documentación del taller.
        </p>
      </div>

      <div class="lab-grid">
        <article class="lab-card animate-in">
          <div class="lab-card-content">
            <div class="lab-card-header">
              <div class="lab-card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              </div>
              <h3 class="lab-card-title">Herramientas</h3>
            </div>
            <p class="lab-card-desc">Herramientas que usamos, evaluamos y documentamos. Ninguna llega al Hub sin meses de uso real antes de ser publicada.</p>
            <div class="lab-card-editorial">
              <span class="lab-card-editorial-item">En uso desde marzo 2026</span>
              <span class="lab-card-editorial-sep" aria-hidden="true"></span>
              <span class="lab-card-editorial-item">Uso diario</span>
              <span class="lab-card-editorial-sep" aria-hidden="true"></span>
              <span class="lab-card-editorial-item">Probado en Android 15</span>
              <span class="lab-card-editorial-sep" aria-hidden="true"></span>
              <span class="lab-card-editorial-item">Última revisión: Julio 2026</span>
            </div>
            <div class="lab-card-meta">
              <span class="lab-card-badge lab-card-badge--verified">MVGN Verified</span>
              <span class="lab-card-count">12 herramientas</span>
            </div>
            <a href="#" class="lab-card-link">
              Explorar herramientas
              <ChevronRight size={14} />
            </a>
          </div>
        </article>

        <article class="lab-card animate-in">
          <div class="lab-card-content">
            <div class="lab-card-header">
              <div class="lab-card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
              </div>
              <h3 class="lab-card-title">Guías</h3>
            </div>
            <p class="lab-card-desc">Guías basadas en configuraciones reales. Sin manuales de fabricante. Solo documentación del laboratorio.</p>
            <div class="lab-card-editorial">
              <span class="lab-card-editorial-item">En actualización continua</span>
              <span class="lab-card-editorial-sep" aria-hidden="true"></span>
              <span class="lab-card-editorial-item">Probado en Android 14 · 15</span>
              <span class="lab-card-editorial-sep" aria-hidden="true"></span>
              <span class="lab-card-editorial-item">Última revisión: Julio 2026</span>
            </div>
            <div class="lab-card-meta">
              <span class="lab-card-badge lab-card-badge--guide">Lab Tested</span>
              <span class="lab-card-count">18 guías</span>
            </div>
            <a href="#" class="lab-card-link">
              Ver guías
              <ChevronRight size={14} />
            </a>
          </div>
        </article>

        <article class="lab-card animate-in">
          <div class="lab-card-content">
            <div class="lab-card-header">
              <div class="lab-card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
              </div>
              <h3 class="lab-card-title">Lab Notes</h3>
            </div>
            <p class="lab-card-desc">Notas del taller. Cambios, observaciones y decisiones técnicas que documentamos a medida que trabajamos.</p>
            <div class="lab-card-editorial">
              <span class="lab-card-editorial-item">Última nota: Julio 2026</span>
              <span class="lab-card-editorial-sep" aria-hidden="true"></span>
              <span class="lab-card-editorial-item">Actualizado semanalmente</span>
              <span class="lab-card-editorial-sep" aria-hidden="true"></span>
              <span class="lab-card-editorial-item">Categoría: Laboratorio</span>
            </div>
            <div class="lab-card-meta">
              <span class="lab-card-badge">Notas</span>
              <span class="lab-card-count">9 notas</span>
            </div>
            <a href="#" class="lab-card-link">
              Leer lab notes
              <ChevronRight size={14} />
            </a>
          </div>
        </article>
      </div>
    </section>

    <!-- ═══ ASISTENCIA ═══ -->
    <section class="section section-planes" id="planes" style="scroll-margin-top: 110px;">
      <div class="section-header animate-in">
        <h2 class="section-title">Si prefieres usar herramientas en lugar de <span class="title-accent">configurarlas</span></h2>
        <p class="section-desc">
          No vendemos soporte. Apoyamos a quienes prefieren dedicar su tiempo a lo que importa.
        </p>
      </div>

      <div class="plans-grid">
        <div class="plans-glow" aria-hidden="true"></div>

        <!-- Lite -->
        <article class="plan-card plan-card--lite animate-in">
          <div class="plan-card-content">
            <div class="plan-card-badge">Lite</div>
            <div class="plan-card-price">
              <span class="plan-amount">$300</span>
              <span class="plan-currency">MXN</span>
            </div>
            <p class="plan-card-sub">Asistencia inicial sin compromiso recurrente</p>

            <ul class="plan-card-list">
              <li><CircleCheck size={14} /> Aplicación para Android</li>
              <li><CircleCheck size={14} /> Guía de instalación y configuración</li>
              <li><CircleCheck size={14} /> Asesoría inicial</li>
              <li><CircleCheck size={14} /> Acceso al Centro de Soporte Digital</li>
              <li><CircleCheck size={14} /> Archivo de instalación incluido</li>
            </ul>

            <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="plan-card-btn">
              Consultar disponibilidad
              <ChevronRight size={16} />
            </a>

            <p class="plan-card-note">
              Una sola configuración. Si con el tiempo la aplicación deja de ser viable, evaluamos alternativas por separado.
            </p>
          </div>
        </article>

        <!-- Soporte Activo -->
        <article class="plan-card plan-card--active animate-in">
          <div class="plan-card-content">
            <span class="plan-card-popular">
              <Sparkles size={12} />
              Para uso frecuente
            </span>

            <div class="plan-card-badge">Soporte Activo</div>
            <div class="plan-card-price">
              <span class="plan-amount">$500</span>
              <span class="plan-currency">MXN</span>
            </div>
            <p class="plan-card-sub">Asistencia continua · 6 meses de cobertura</p>

            <ul class="plan-card-list">
              <li><CircleCheck size={14} /> Todo lo de Lite</li>
              <li class="plan-card-list-divider" aria-hidden="true"></li>
              <li><Shield size={14} /> Soporte prioritario por WhatsApp</li>
              <li><Shield size={14} /> Seguimiento de alternativas disponibles</li>
              <li><Shield size={14} /> Asistencia para migración durante el período</li>
            </ul>

            <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="plan-card-btn plan-card-btn--primary">
              Saber más
              <ChevronRight size={16} />
            </a>

            <p class="plan-card-note">
              Durante 6 meses cubrimos migración a una alternativa funcional si es necesario, sin costo adicional.
            </p>
          </div>
        </article>
      </div>

      <!-- Collapsible details -->
      <details class="plan-details animate-in">
        <summary class="plan-details-summary">
          <div class="plan-details-summary-left">
            <div class="plan-details-summary-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <span class="plan-details-summary-text">Información importante</span>
