    align-items: center;
    gap: var(--space-12);
  }

  /* ── Pull-quote card ── */
  .manifesto-pullquote {
    position: relative;
    display: flex;
    width: 100%;
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .manifesto-pullquote:hover {
    border-color: rgba(220, 38, 38, 0.12);
  }

  .manifesto-pullquote-accent {
    flex-shrink: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--color-primary) 0%, rgba(220, 38, 38, 0.2) 100%);
    border-radius: 0 2px 2px 0;
  }

  .manifesto-pullquote-body {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-8) var(--space-8);
  }

  .manifesto-pullquote-mark {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.2;
    flex-shrink: 0;
    margin-top: -0.15em;
    font-family: Georgia, serif;
  }

  .manifesto-pullquote-body p {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 500;
    color: var(--color-text-secondary);
    line-height: 1.6;
    letter-spacing: -0.02em;
    margin: 0;
    font-style: normal;
  }

  /* ── Stats grid ── */
  .manifesto-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    width: 100%;
  }

  .manifesto-stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-4);
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    text-align: center;
  }

  .manifesto-stat-card:hover {
    transform: translateY(-2px);
    border-color: rgba(220, 38, 38, 0.1);
    background: rgba(255, 255, 255, 0.03);
  }

  .manifesto-stat-num {
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .manifesto-stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.4;
  }

  /* ── Dynamic background glow ── */
  .manifesto-glow {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(ellipse 50% 50% at 50% 50%, rgba(220, 38, 38, 0.08) 0%, transparent 60%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
    animation: manifestoGlowPulse 8s ease-in-out infinite;
  }

  @keyframes manifestoGlowPulse {
    0%, 100% {
      opacity: 0.4;
      transform: translateX(-50%) scale(1);
    }
    50% {
      opacity: 1;
      transform: translateX(-50%) scale(1.15);
    }
  }

  /* ══════════════════════════════════════════════════
     PROCESS BAR — Horizontal stepper
     ══════════════════════════════════════════════════ */
  .section-timeline {
    position: relative;
    max-width: 850px;
  }

  .process-bar {
    display: flex;
    align-items: stretch;
    width: 100%;
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .process-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 18px 8px;
    text-align: center;
    cursor: default;
    transition: all 0.25s ease;
    position: relative;
    background: transparent;
  }

  .process-step::after {
    content: '';
    position: absolute;
    right: 0;
    top: 20%;
    height: 60%;
    width: 1px;
    background: var(--glass-border);
    transition: opacity 0.25s ease;
  }

  .process-step:last-child::after {
    display: none;
  }

  .process-step:hover,
  .process-step.active {
    background: rgba(220, 38, 38, 0.04);
  }

  .process-step:hover::after,
  .process-step.active::after {
    opacity: 0;
  }

  .process-step-num {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-primary);
    opacity: 0.4;
    letter-spacing: 0.12em;
    transition: all 0.25s ease;
  }

  .process-step:hover .process-step-num,
  .process-step.active .process-step-num {
    opacity: 1;
  }

  .process-step-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    transition: all 0.25s ease;
  }

  .process-step:hover .process-step-title,
  .process-step.active .process-step-title {
    color: var(--color-primary);
  }

  /* ── Description box ── */
  .process-desc-box {
    margin-top: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    min-height: 68px;
    display: flex;
    align-items: center;
    transition: border-color var(--transition-base);
  }

  .process-desc-box p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ══════════════════════════════════════════════════
     LAB CARDS — 3 columnas editoriales
     ══════════════════════════════════════════════════ */
  .section-lab {
    position: relative;
    max-width: 1100px;
  }

  .lab-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .lab-card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--glass-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    transition: all var(--transition-base);
    position: relative;
  }

  .lab-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, rgba(220, 38, 38, 0.3) 0%, transparent 80%);
    border-radius: 2px 0 0 2px;
    pointer-events: none;
  }

  .lab-card:nth-child(2)::after {
    background: linear-gradient(180deg, rgba(16, 185, 129, 0.3) 0%, transparent 80%);
  }

  .lab-card:nth-child(3)::after {
    background: linear-gradient(180deg, rgba(139, 92, 246, 0.3) 0%, transparent 80%);
  }

  .lab-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
  }

  .lab-card-content {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    height: 100%;
  }

  .lab-card-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .lab-card-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: rgba(220, 38, 38, 0.08);
    color: var(--color-primary);
    transition: all var(--transition-fast);
  }

  .lab-card:hover .lab-card-icon {
    background: rgba(220, 38, 38, 0.14);
  }

  .lab-card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .lab-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
    flex: 1;
  }

  .lab-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .lab-card-badge {
    display: inline-flex;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-full);
    color: var(--color-primary);
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.12);
  }

  .lab-card-badge--verified {
    color: var(--color-green);
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.15);
  }

  .lab-card-badge--guide {
    color: var(--color-purple);
    background: rgba(139, 92, 246, 0.08);
    border-color: rgba(139, 92, 246, 0.12);
  }

  .lab-card-count {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .lab-card-editorial {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-text-tertiary);
    opacity: 0.65;
    letter-spacing: -0.02em;
    margin-top: -2px;
  }

  .lab-card-editorial-item {
    white-space: nowrap;
  }

  .lab-card-editorial-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-tertiary);
    opacity: 0.3;
    flex-shrink: 0;
  }

  .lab-card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    background: var(--glass-bg-strong);
    border: 1px solid var(--glass-border);
    transition: all var(--transition-fast);
    align-self: flex-start;
  }

  .lab-card-link:hover {
    color: var(--color-text-primary);
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.06);
  }



  /* ══════════════════════════════════════════════════
     PRINCIPLES — 3 principios de filosofía
     ══════════════════════════════════════════════════ */
  .principles-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 720px;
    margin: 0 auto;
  }

  .principle-card {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    transition: all var(--transition-base);
    position: relative;
  }

  .principle-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.1);
  }



  .principle-num {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    color: rgba(220, 38, 38, 0.15);
    flex-shrink: 0;
    min-width: 1.2em;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.04em;
  }

  .principle-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .principle-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .principle-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }



  /* ══════════════════════════════════════════════════
     PLANS & PRICING
     ══════════════════════════════════════════════════ */
  .section-planes {
    scroll-margin-top: 110px;
    max-width: 1100px;
  }

  .plans-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .plans-glow {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(220, 38, 38, 0.06) 0%, transparent 60%);
    filter: blur(100px);
    pointer-events: none;
  }

  /* ── Plan Card ── */
  .plan-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--transition-base);
    background: var(--glass-bg);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid var(--glass-border);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
  }

  .plan-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  /* ── SILVER (Lite) ── */
  .plan-card--lite::before {
    background: radial-gradient(ellipse 80% 60% at 50% -20%, rgba(255, 255, 255, 0.08) 0%, transparent 60%);
  }

  .plan-card--lite:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 12px 48px rgba(0, 0, 0, 0.35),
      0 0 60px rgba(255, 255, 255, 0.04);
  }

  .plan-card--lite:hover::before {
    opacity: 1;
  }

  /* ── GOLD (Soporte Activo) ── */
  .plan-card--active {
    border-color: rgba(212, 168, 67, 0.15);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3), inset 0 0 0 1px rgba(212, 168, 67, 0.08);
  }

  .plan-card--active::before {
    background: radial-gradient(ellipse 80% 70% at 50% -10%, rgba(212, 168, 67, 0.1) 0%, transparent 60%);
  }

  .plan-card--active:hover {
    transform: translateY(-3px);
    border-color: rgba(212, 168, 67, 0.25);
    box-shadow:
      0 12px 48px rgba(0, 0, 0, 0.4),
      0 0 60px rgba(212, 168, 67, 0.08),
      inset 0 0 0 1px rgba(212, 168, 67, 0.15);
  }

  .plan-card--active:hover::before {
    opacity: 1;
  }

  /* Gold accents for Soporte Activo */
  .plan-card--active .plan-card-popular {
    color: #D4A843;
    background: rgba(212, 168, 67, 0.08);
    border-color: rgba(212, 168, 67, 0.12);
  }

  .plan-card--active .plan-card-btn--primary {
    background: #D4A843;
    border-color: #D4A843;
    color: #1A1A1A;
    box-shadow: 0 2px 16px rgba(212, 168, 67, 0.2);
  }

  .plan-card--active .plan-card-btn--primary:hover {
    background: #E0B84C;
    border-color: #E0B84C;
    box-shadow: 0 4px 24px rgba(212, 168, 67, 0.3);
    color: #1A1A1A;
  }

  .plan-card-content {
    position: relative;
    z-index: 1;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .plan-card-popular {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1-5);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.1);
    align-self: flex-start;
    margin-bottom: var(--space-1);
  }

  .plan-card-badge {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .plan-card-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .plan-amount {
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .plan-currency {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-tertiary);
    letter-spacing: 0.05em;
  }

  .plan-card-sub {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .plan-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .plan-card-list li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    line-height: var(--leading-normal);
  }

  .plan-card-list li svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .plan-card--lite .plan-card-list li svg {
    color: var(--color-text-tertiary);
  }

  .plan-card--active .plan-card-list li svg {
    color: #D4A843;
  }

  .plan-card-list-divider {
    height: 1px;
    background: var(--glass-border);
    margin: var(--space-1) 0;
  }

  .plan-card-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    align-self: flex-start;
    text-decoration: none;
    transition: all var(--transition-base);
    background: var(--glass-bg-strong);
    color: var(--color-text-secondary);
    border: 1px solid var(--glass-border);
  }

  .plan-card-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-primary);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .plan-card-btn--primary {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-text-primary);
    box-shadow: 0 2px 16px rgba(220, 38, 38, 0.2);
  }

  .plan-card-btn--primary:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    color: var(--color-text-primary);
    box-shadow: 0 4px 24px rgba(220, 38, 38, 0.3);
    transform: translateY(-1px);
  }

  .plan-card-note {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    opacity: 0.5;
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 32ch;
  }

  /* ── Collapsible details ── */
  .plan-details {
    margin-top: var(--space-8);
    border-radius: var(--radius-lg);
    background: transparent;
    border: 1px solid rgba(220, 38, 38, 0.08);
    overflow: hidden;
    transition: all var(--transition-base);
    position: relative;
  }

  .plan-details::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, rgba(220, 38, 38, 0.4), rgba(220, 38, 38, 0.1));
    border-radius: 0 2px 2px 0;
    transition: all var(--transition-base);
  }

  .plan-details[open] {
    border-color: rgba(220, 38, 38, 0.18);
    background: rgba(220, 38, 38, 0.02);
  }

  .plan-details[open]::before {
    background: linear-gradient(180deg, rgba(220, 38, 38, 0.7), rgba(220, 38, 38, 0.2));
  }

  .plan-details-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    list-style: none;
    user-select: none;
    -webkit-user-select: none;
    transition: all var(--transition-fast);
  }

  .plan-details-summary:hover {
    background: rgba(220, 38, 38, 0.03);
  }

  .plan-details-summary::-webkit-details-marker {
    display: none;
  }

  .plan-details-summary-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .plan-details-summary-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(220, 38, 38, 0.08);
    color: var(--color-primary);
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .plan-details[open] .plan-details-summary-icon {
    background: rgba(220, 38, 38, 0.15);
  }

  .plan-details-summary:hover .plan-details-summary-icon {
    background: rgba(220, 38, 38, 0.14);
  }

  .plan-details-summary-text {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
  }

  .plan-details-chevron {
    color: var(--color-text-tertiary);
    transition: transform var(--transition-base);
    flex-shrink: 0;
  }

  .plan-details[open] .plan-details-chevron {
    transform: rotate(180deg);
    color: var(--color-primary);
  }

  .plan-details-body {
    padding: var(--space-1) var(--space-5) var(--space-6);
    display: flex;
