---
// ══════════════════════════════════════════════════════════════
// MVGN Labs — Legal Notice Component
// ══════════════════════════════════════════════════════════════
---

<div class="legal-notice">
  <p>
    MVGN Labs proporciona servicios de configuración, documentación y asistencia técnica sobre aplicaciones y servicios desarrollados por terceros. MVGN Labs no es desarrollador, propietario, distribuidor oficial ni representante de las marcas o aplicaciones mencionadas.
  </p>
</div>

<style is:global>
  .legal-notice {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-4) var(--space-10);
  }

  .legal-notice p {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
    text-align: center;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  @media (max-width: 640px) {
    .legal-notice {
      padding: var(--space-4);
    }
  }
</style>
