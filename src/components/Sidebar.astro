---
import { getCollection } from 'astro:content';
import House from '@lucide/astro/icons/house';
import CircleQuestionMark from '@lucide/astro/icons/circle-question-mark';
import Mail from '@lucide/astro/icons/mail';

export interface Props {
  currentApp?: string;
  isMobile?: boolean;
}

const navItems = [
  { label: 'Centro de Soporte', href: '/', icon: House },
  { label: 'Preguntas Frecuentes', href: '/faq', icon: CircleQuestionMark },
  { label: 'Contacto', href: '/contact', icon: Mail },
];

const { currentApp = '', isMobile = false } = Astro.props;

const allApps = await getCollection('apps');
const appList = allApps.map(app => ({
  slug: app.id,
  title: app.data.title,
}));

const accentFor = (slug: string) => {
  if (slug === 'todo-en-uno') return 'green';
  if (slug === 'biblioteca-personal') return 'purple';
  return 'red';
};
---

<aside class="sidebar" data-mobile={isMobile}>
  <button class="sidebar-toggle" id="docs-sidebar-toggle" aria-label="Ocultar sidebar" type="button">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
  </button>
  <div class="sidebar-frame">
    <div class="sidebar-glass">
      <div class="sidebar-inner">
        <a href="/" class="sidebar-brand">
          <div class="brand-logo">
            <img src="/favicon.png" alt="MVGN Labs" class="brand-img" />
          </div>
          <div class="brand-text">
            <span class="brand-name">MVGN Labs</span>
            <span class="brand-subtitle">Centro de Soporte Digital</span>
          </div>
        </a>

        <nav class="sidebar-nav">
          {navItems.map((item) => {
            const Icon = item.icon;
            const isActive = Astro.url.pathname === '/'
              ? currentApp === '' && item.href === '/'
              : item.href === Astro.url.pathname;
            return (
              <a
                href={item.href}
                class:list={{
                  'nav-item': true,
                  'nav-item--active': isActive,
                }}
              >
                <span class="nav-item-icon">
                  <Icon size={16} />
                </span>
                <span class="nav-label">{item.label}</span>
                {isActive && <span class="nav-indicator" aria-hidden="true"></span>}
              </a>
            );
          })}

          {appList.length > 0 && (
            <div class="nav-section">
              <span class="nav-section-title">Aplicaciones</span>
              {appList.map((app) => (
                <a
                  href={`/support/${app.slug}`}
                  class:list={{
                    'nav-item': true,
                    'nav-item--app': true,
                    [`nav-item--${accentFor(app.slug)}`]: true,
                    'nav-item--active': app.slug === currentApp,
                  }}
                >
                  <span class="nav-app-dot" aria-hidden="true"></span>
                  <span class="nav-label">{app.title}</span>
                  {app.slug === currentApp && <span class="nav-indicator" aria-hidden="true"></span>}
                </a>
              ))}
            </div>
          )}
        </nav>

        <div class="sidebar-version">v1.7</div>
      </div>
    </div>
  </div>
</aside>

<style is:global>
  .sidebar {
    position: sticky;
    top: calc(52px + var(--space-4));
    width: var(--sidebar-width);
    max-height: calc(100vh - 52px - var(--space-4) - var(--space-4));
    z-index: 100;
    display: flex;
    flex-direction: column;
    padding: 0 var(--space-3);
    transition: all var(--transition-slow);
  }

  .sidebar[data-collapsed="true"] {
    width: 0;
    padding: 0;
    visibility: hidden;
  }

  /* ── TOGGLE ── */
  .sidebar-toggle {
    position: absolute;
    top: 50%;
    right: -14px;
    transform: translateY(-50%);
    z-index: 10;
    width: 28px;
    height: 48px;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-left: none;
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: all var(--transition-base);
    padding: 0;
  }

  .sidebar-toggle:hover {
    color: var(--color-text-primary);
    background: var(--glass-bg-strong);
  }

  .sidebar[data-collapsed="true"] .sidebar-toggle {
    visibility: visible;
    right: auto;
    left: 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    border: 1px solid var(--glass-border);
    border-left: 1px solid var(--glass-border);
  }

  .sidebar[data-collapsed="true"] .sidebar-toggle svg {
    transform: scaleX(-1);
  }

  .sidebar-frame {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    padding: 1px;
    background: linear-gradient(180deg, rgba(255,255,255,0.08), var(--glass-backdrop));
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .sidebar-glass {
    flex: 1;
    border-radius: calc(var(--radius-xl) - 1px);
    background: var(--glass-bg);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    padding: var(--space-5);
    overflow-y: auto;
  }

  /* ── BRAND ── */
  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 0 0 var(--space-5) 0;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: var(--space-5);
  }

  .brand-logo {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, rgba(220, 38, 38, 0.9), rgba(220, 38, 38, 0.6));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    box-shadow: 0 0 16px rgba(220, 38, 38, 0.15);
    overflow: hidden;
  }

  .brand-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .brand-name {
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-tight);
  }

  .brand-subtitle {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1.2;
  }

  /* ── NAV ── */
  .sidebar-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .nav-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text-secondary);
  }

  .nav-item--active {
    background: rgba(220, 38, 38, 0.08);
    color: var(--color-primary);
  }

  .nav-item-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity var(--transition-fast);
  }

  .nav-item:hover .nav-item-icon {
    opacity: 0.8;
  }

  .nav-item--active .nav-item-icon {
    opacity: 1;
  }

  .nav-item-icon svg {
    display: block;
  }

  .nav-label {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-indicator {
    width: 4px;
    height: 16px;
    border-radius: 2px;
    background: var(--color-primary);
    margin-left: auto;
    flex-shrink: 0;
  }

  /* ── APP SECTION ── */
  .nav-section {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-section-title {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    padding: 0 var(--space-3);
    margin-bottom: var(--space-1);
    opacity: 0.5;
  }

  .nav-app-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-tertiary);
    flex-shrink: 0;
    opacity: 0.4;
  }

  .nav-item--green .nav-app-dot,
  .nav-item--green.nav-item--active .nav-app-dot {
    background: var(--color-green);
    opacity: 0.7;
  }

  .nav-item--purple .nav-app-dot,
  .nav-item--purple.nav-item--active .nav-app-dot {
    background: var(--color-purple);
    opacity: 0.7;
  }

  .nav-item--green.nav-item--active {
    background: var(--color-green-subtle);
    color: var(--color-green);
  }

  .nav-item--green.nav-item--active .nav-indicator {
    background: var(--color-green);
  }

  .nav-item--purple.nav-item--active {
    background: var(--color-purple-subtle);
    color: var(--color-purple);
  }

  .nav-item--purple.nav-item--active .nav-indicator {
    background: var(--color-purple);
  }

  /* ── VERSION ── */
  .sidebar-version {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.15);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-align: center;
    padding-top: var(--space-3);
    margin-top: auto;
  }

  @media (max-width: 1024px) {
    .sidebar {
      display: none;
    }

    .sidebar[data-mobile="true"] {
      display: flex;
    }
  }
</style>
