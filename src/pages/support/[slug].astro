---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

import Smartphone from '@lucide/astro/icons/smartphone';
import Tv from '@lucide/astro/icons/tv';
import Clock from '@lucide/astro/icons/clock';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import MessageCircle from '@lucide/astro/icons/message-circle';
import Mail from '@lucide/astro/icons/mail';
import CircleQuestionMark from '@lucide/astro/icons/circle-question-mark';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map((app) => ({
    params: { slug: app.id },
    props: { app },
  }));
}

const { app } = Astro.props;
const { Content } = await render(app);

const iconMap: Record<string, any> = {
  'todo-en-uno': Smartphone,
  'biblioteca-personal': Tv,
};
const AppIcon = iconMap[app.data.slug] || Smartphone;

const formatDate = (date?: Date) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<DocsLayout
  title={app.data.title}
  description={app.data.description}
  currentApp={app.data.slug}
>
  <article class="app-doc" data-accent={app.data.slug}>
    <header class="doc-hero">
      <div class="doc-hero-glow" aria-hidden="true"></div>
      <div class="doc-hero-body">
        <div class="doc-hero-icon">
          <AppIcon size={24} />
        </div>
        <div class="doc-hero-text">
          <div class="doc-hero-meta">
            {app.data.tags?.map((tag) => (
              <span class="doc-hero-tag">{tag}</span>
            ))}
            {app.data.version && (
              <span class="doc-hero-version">v{app.data.version}</span>
            )}
          </div>
          <h1 class="doc-hero-title">{app.data.title}</h1>
          <p class="doc-hero-desc">{app.data.description}</p>
          {app.data.updatedAt && (
            <span class="doc-hero-date">
              <Clock size={13} />
              Actualizado: {formatDate(app.data.updatedAt)}
            </span>
          )}
        </div>
      </div>
    </header>

    <div class="doc-layout">
      <div class="doc-content" id="doc-content">
        <Content />
      </div>

      <aside class="doc-side-progress" id="doc-side-progress">
        <div class="doc-side-progress-inner">
          <p class="doc-side-progress-label">En esta guía</p>
          <nav class="doc-side-progress-nav" id="doc-progress-nav" aria-label="Pasos de la guía"></nav>
        </div>
      </aside>
    </div>

    <div class="doc-contact">
      <div class="doc-contact-channels">
        <div class="contact-channels-header">
          <h3 class="contact-channels-title">Canales directos</h3>
          <span class="contact-channels-sub">Elige el que prefieras</span>
        </div>

        <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="contact-channel">
          <div class="contact-channel-glass"></div>
          <div class="contact-channel-body">
            <div class="contact-channel-icon">
              <MessageCircle size={18} />
            </div>
            <div class="contact-channel-info">
              <span class="contact-channel-label">WhatsApp</span>
              <span class="contact-channel-hint">Respuesta en menos de 1 hora</span>
            </div>
          </div>
          <ChevronRight size={16} class="contact-channel-arrow" />
        </a>

        <a href="mailto:mvgnlabs@proton.me" class="contact-channel">
          <div class="contact-channel-glass"></div>
          <div class="contact-channel-body">
            <div class="contact-channel-icon">
              <Mail size={18} />
            </div>
            <div class="contact-channel-info">
              <span class="contact-channel-label">Correo</span>
              <span class="contact-channel-hint">Respuesta en menos de 24 horas</span>
            </div>
          </div>
          <ChevronRight size={16} class="contact-channel-arrow" />
        </a>

        <a href="/faq" class="contact-channel">
          <div class="contact-channel-glass"></div>
          <div class="contact-channel-body">
            <div class="contact-channel-icon">
              <CircleQuestionMark size={18} />
            </div>
            <div class="contact-channel-info">
              <span class="contact-channel-label">FAQ</span>
              <span class="contact-channel-value">Preguntas frecuentes</span>
              <span class="contact-channel-hint">Respuestas inmediatas</span>
            </div>
          </div>
          <ChevronRight size={16} class="contact-channel-arrow" />
        </a>

        <div class="contact-support">
          <span class="contact-support-dot"></span>
          <span class="contact-support-text">Soporte directo sin complicaciones</span>
        </div>
      </div>
    </div>

    <footer class="doc-terms">
      <p class="doc-terms-title">Términos del servicio</p>
      <ul class="doc-terms-list">
        <li>Las aplicaciones son desarrolladas por terceros. MVGN Labs actúa como facilitador técnico.</li>
        <li>No se garantiza el funcionamiento indefinido de una app específica. El valor del servicio está en la capacidad de migración.</li>
        <li>MVGN Labs no se responsabiliza por daños o pérdidas derivados del uso del software.</li>
        <li>El cliente es responsable de usar el servicio conforme a las leyes de su jurisdicción.</li>
      </ul>
    </footer>
  </article>
</DocsLayout>

<script>
  (function() {
    const sections = document.querySelectorAll('.step-section');
    const progressNav = document.getElementById('doc-progress-nav');
    let current = 0;

    if (!sections.length) return;

    // ── Extract step titles and inject header ──
    const stepTitles = [];
    sections.forEach((section, index) => {
      // Use H2 text as step title
      const h2 = section.querySelector('h2');
      const title = h2 ? h2.textContent.trim() : `Paso ${index + 1}`;
      stepTitles.push(title);

      // Inject header: dot + "Paso N"
      const header = document.createElement('div');
      header.className = 'step-section-header';

      const dot = document.createElement('span');
      dot.className = 'step-section-dot';

      const label = document.createElement('span');
      label.className = 'step-section-label';
      label.textContent = `Paso ${index + 1}`;

      header.appendChild(dot);
      header.appendChild(label);
      section.insertBefore(header, section.firstChild);

      // Mark first section as visible
      if (index === 0) section.setAttribute('data-visible', '');
    });

    // ── Build progress sidebar nav ──
    stepTitles.forEach((title, index) => {
      const btn = document.createElement('button');
      btn.className = 'side-progress-item';
      btn.textContent = title;
      btn.setAttribute('data-index', String(index));
      btn.addEventListener('click', () => {
        sections[index].scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      progressNav.appendChild(btn);
    });

    const sideItems = progressNav.querySelectorAll('.side-progress-item');

    // ── Progress update ──
    function updateProgress(index) {
      if (index === current && index === 0) {
        // still need to run on first render
      }
      current = index;

      // Sidebar items
      sideItems.forEach((el, i) => {
        el.classList.toggle('side-progress-item--active', i === index);
        el.classList.toggle('side-progress-item--done', i < index);
      });

      // Section visibility
      sections.forEach((el, i) => {
        el.toggleAttribute('data-visible', i <= index);
      });


    }

    // ── IntersectionObserver ──
    const observer = new IntersectionObserver((entries) => {
      let bestIndex = -1;
      let bestRatio = 0;
      entries.forEach(entry => {
        const idx = Array.from(sections).indexOf(entry.target);
        if (entry.isIntersecting && entry.intersectionRatio > bestRatio) {
          bestRatio = entry.intersectionRatio;
          bestIndex = idx;
        }
      });
      if (bestIndex >= 0) {
        updateProgress(bestIndex);
      }
    }, { threshold: [0.2, 0.4, 0.6], rootMargin: '-60px 0px -30% 0px' });

    sections.forEach(s => observer.observe(s));

    // ── Lightbox ──
    const lightbox = document.createElement('div');
    lightbox.className = 'doc-lightbox';
    const lightboxImg = document.createElement('img');
    lightbox.appendChild(lightboxImg);
    document.body.appendChild(lightbox);

    document.querySelectorAll('.screenshot-frame img').forEach(img => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

    lightbox.addEventListener('click', () => {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        lightbox.classList.remove('open');
        document.body.style.overflow = '';
      }
    });

    // ── Init ──
    updateProgress(0);
  })();
</script>

<style is:global>
  /* ═══════════════════════════════════════
     ACCENT VARIABLES
     ═══════════════════════════════════════ */
  .app-doc {
    --accent: var(--color-primary);
    --accent-subtle: rgba(220, 38, 38, 0.08);
    --accent-glow: rgba(220, 38, 38, 0.12);
    --accent-border: rgba(220, 38, 38, 0.15);
  }

  [data-accent="todo-en-uno"] {
    --accent: var(--color-green);
    --accent-subtle: var(--color-green-subtle);
    --accent-glow: var(--color-green-glow);
    --accent-border: var(--color-green-border);
  }

  [data-accent="biblioteca-personal"] {
    --accent: var(--color-purple);
    --accent-subtle: var(--color-purple-subtle);
    --accent-glow: var(--color-purple-glow);
    --accent-border: var(--color-purple-border);
  }

  /* ═══════════════════════════════════════
     HERO
     ═══════════════════════════════════════ */
  .doc-hero {
    position: relative;
    margin-bottom: var(--space-12);
    overflow: hidden;
    border-radius: var(--radius-xl);
    background: var(--glass-bg);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .doc-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--accent-glow) 0%, rgba(255,255,255,0.04) 50%, transparent 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  .doc-hero-glow {
    position: absolute;
    top: -120px;
    right: -120px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 60%);
    pointer-events: none;
  }

  .doc-hero-body {
    position: relative;
    z-index: 1;
    display: flex;
    gap: var(--space-6);
    padding: var(--space-10);
    align-items: flex-start;
  }

  .doc-hero-icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: var(--accent);
    border: 1px solid var(--accent);
    color: #fff;
    box-shadow: 0 0 24px var(--accent-glow);
  }

  .doc-hero-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .doc-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .doc-hero-tag {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: var(--accent-subtle);
    color: var(--accent);
    border: 1px solid var(--accent-border);
    letter-spacing: var(--tracking-wide);
  }

  .doc-hero-version {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text-tertiary);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .doc-hero-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin: 0;
  }

  .doc-hero-desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 580px;
    margin: 0;
  }

  .doc-hero-date {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1-5);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* ═══════════════════════════════════════
     TWO-COLUMN LAYOUT
     ═══════════════════════════════════════ */
  .doc-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--space-10);
    align-items: start;
    position: relative;
  }

  .doc-content {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  /* ═══════════════════════════════════════
     SIDE PROGRESS
     ═══════════════════════════════════════ */
  .doc-side-progress {
    position: sticky;
    top: calc(52px + var(--space-8));
    z-index: 5;
  }

  .doc-side-progress-inner {
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    background: var(--glass-backdrop);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .doc-side-progress-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 var(--space-4);
  }

  .side-progress-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: var(--space-2) var(--space-3) var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-tertiary);
    background: none;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
    position: relative;
    font-family: inherit;
    line-height: var(--leading-normal);
  }

  .side-progress-item:hover {
    color: var(--color-text-secondary);
    background: var(--glass-bg);
  }

  .side-progress-item--active {
    color: var(--accent);
    background: var(--accent-subtle);
  }

  .side-progress-item--active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 3px;
    background: var(--accent);
    border-radius: 2px;
  }

  .side-progress-item--done {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  /* ═══════════════════════════════════════
     STEP SECTIONS — exp-card glass pattern
     ═══════════════════════════════════════ */
  .doc-content .step-section {
    position: relative;
    padding: var(--space-8);
    margin-bottom: var(--space-8);
    border-radius: var(--radius-xl);
    background: var(--glass-bg);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    overflow: hidden;
  }

  /* Gradient border */
  .doc-content .step-section::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--accent-glow) 0%, rgba(255,255,255,0.04) 50%, transparent 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  .doc-content .step-section > * {
    position: relative;
    z-index: 1;
  }

  /* Step header: dot + "Paso N" */
  .step-section-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .step-section-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 14px var(--accent-glow);
    flex-shrink: 0;
  }

  .step-section-label {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Step heading */
  .doc-content .step-section h2 {
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 var(--space-4);
    color: var(--color-text-primary);
    line-height: var(--leading-tight);
  }

  .doc-content .step-section h3 {
    font-size: var(--text-lg);
    font-weight: 700;
    margin: var(--space-5) 0 var(--space-2);
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .doc-content .step-section p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
    max-width: 65ch;
  }

  .doc-content .step-section ul,
  .doc-content .step-section ol {
    margin-bottom: var(--space-3);
    padding-left: var(--space-5);
    font-size: var(--text-base);
  }

  .doc-content .step-section li {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-2);
  }

  .doc-content .step-section li strong {
    color: var(--color-text-primary);
  }

  .doc-content .step-section strong, 
  .doc-content .step-section b {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  /* ═══════════════════════════════════════
     HEADINGS outside step-sections
     ═══════════════════════════════════════ */
  .doc-content > h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: var(--space-12) 0 var(--space-4);
    color: var(--color-text-primary);
  }

  .doc-content > p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    max-width: 65ch;
  }

  .doc-content > ul,
  .doc-content > ol {
    margin-bottom: var(--space-4);
    padding-left: var(--space-5);
    font-size: var(--text-base);
  }

  .doc-content > li {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-2);
  }

  /* ═══════════════════════════════════════
     SCREENSHOTS
     ═══════════════════════════════════════ */
  .screenshot-pair {
    display: flex;
    gap: var(--space-6);
    width: 100%;
    justify-content: center;
    margin: var(--space-8) 0;
  }

  .doc-content .screenshot-frame {
    flex: 1;
    max-width: 340px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .doc-content .screenshot-frame:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  .doc-content .step-section .screenshot-frame {
    max-width: 400px;
  }

  /* Single screenshot */
  .doc-content .screenshot-frame:only-child {
    max-width: 400px;
  }

  /* ═══════════════════════════════════════
     CALLOUT inside steps
     ═══════════════════════════════════════ */
  .doc-content .step-section .callout {
    margin: var(--space-6) 0;
  }

  .doc-content .step-section .callout p {
    font-size: var(--text-base);
  }

  /* ═══════════════════════════════════════
     CONTACT CHANNELS (same as index)
     ═══════════════════════════════════════ */
  .doc-contact {
    margin-top: var(--space-12);
  }

  .doc-contact-channels {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .doc-contact-channels .contact-channels-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-1);
  }

  .doc-contact-channels .contact-channels-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .doc-contact-channels .contact-channels-sub {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .contact-channel {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .contact-channel-glass {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.04);
    pointer-events: none;
    transition: all var(--transition-base);
  }

  .contact-channel:hover {
    transform: translateY(-2px);
  }

  .contact-channel:hover .contact-channel-glass {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .contact-channel-body {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .contact-channel-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(220, 38, 38, 0.06);
    border: 1px solid rgba(220, 38, 38, 0.1);
    color: var(--color-primary);
    flex-shrink: 0;
    transition: all var(--transition-fast);
