    border-radius: 2px 0 0 2px;
    pointer-events: none;
  }

  .lab-card:nth-child(2)::after {
    background: linear-gradient(180deg, rgba(16, 185, 129, 0.3) 0%, transparent 80%);
  }

  .lab-card:nth-child(3)::after {
    background: linear-gradient(180deg, rgba(139, 92, 246, 0.3) 0%, transparent 80%);
  }

  .lab-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
  }

  .lab-card-content {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    height: 100%;
  }

  .lab-card-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .lab-card-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: rgba(75, 163, 242, 0.08);
    color: var(--color-primary);
    transition: all var(--transition-fast);
  }

  .lab-card:hover .lab-card-icon {
    background: rgba(75, 163, 242, 0.14);
  }

  .lab-card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .lab-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
    flex: 1;
  }

  .lab-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .lab-card-badge {
    display: inline-flex;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-full);
    color: var(--color-primary);
    background: rgba(75, 163, 242, 0.08);
    border: 1px solid rgba(75, 163, 242, 0.12);
  }

  .lab-card-badge--verified {
    color: var(--color-green);
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.15);
  }

  .lab-card-badge--guide {
    color: var(--color-purple);
    background: rgba(139, 92, 246, 0.08);
    border-color: rgba(139, 92, 246, 0.12);
  }

  .lab-card-count {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .lab-card-editorial {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-text-tertiary);
    opacity: 0.65;
    letter-spacing: -0.02em;
    margin-top: -2px;
  }

  .lab-card-editorial-item {
    white-space: nowrap;
  }

  .lab-card-editorial-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-tertiary);
    opacity: 0.3;
    flex-shrink: 0;
  }

  .lab-card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    background: var(--glass-bg-strong);
    border: 1px solid var(--glass-border);
    transition: all var(--transition-fast);
    align-self: flex-start;
  }

  .lab-card-link:hover {
    color: var(--color-text-primary);
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.06);
  }

  .lab-grid > .animate-in {
    height: 100%;
  }

  .lab-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-8);
  }

  .lab-cta .lab-card-link {
    padding: var(--space-3) var(--space-8);
  }

  /* ══════════════════════════════════════════════════
     FILOSOFÍA — Carta / Documento firmado
     ══════════════════════════════════════════════════ */
  .filosofia-carta {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-10) var(--space-8);
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    position: relative;
  }

  .filosofia-texto {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .filosofia-texto strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .filosofia-cierre {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    font-style: italic;
  }

  .filosofia-firma {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--glass-border);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .filosofia-firma-linea {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .filosofia-firma-cargo {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }



  /* ══════════════════════════════════════════════════
     PLANS & PRICING
     ══════════════════════════════════════════════════ */
  .section-planes {
    scroll-margin-top: 110px;
    max-width: 1100px;
  }

  .plans-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .plans-glow {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(75, 163, 242, 0.06) 0%, transparent 60%);
    filter: blur(100px);
    pointer-events: none;
  }

  /* ── Plan Card ── */
  .plan-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--transition-base);
    background: var(--glass-bg);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid var(--glass-border);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
  }

  .plan-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  /* ── SILVER (Lite) ── */
  .plan-card--lite::before {
    background: radial-gradient(ellipse 80% 60% at 50% -20%, rgba(255, 255, 255, 0.08) 0%, transparent 60%);
  }

  .plan-card--lite:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 12px 48px rgba(0, 0, 0, 0.35),
      0 0 60px rgba(255, 255, 255, 0.04);
  }

  .plan-card--lite:hover::before {
    opacity: 1;
  }

  /* ── GOLD (Soporte Activo) ── */
  .plan-card--active {
    border-color: rgba(212, 168, 67, 0.15);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3), inset 0 0 0 1px rgba(212, 168, 67, 0.08);
  }

  .plan-card--active::before {
    background: radial-gradient(ellipse 80% 70% at 50% -10%, rgba(212, 168, 67, 0.1) 0%, transparent 60%);
  }

  .plan-card--active:hover {
    transform: translateY(-3px);
    border-color: rgba(212, 168, 67, 0.25);
    box-shadow:
      0 12px 48px rgba(0, 0, 0, 0.4),
      0 0 60px rgba(212, 168, 67, 0.08),
      inset 0 0 0 1px rgba(212, 168, 67, 0.15);
  }

  .plan-card--active:hover::before {
    opacity: 1;
  }

  /* Gold accents for Soporte Activo */
  .plan-card--active .plan-card-popular {
    color: #D4A843;
    background: rgba(212, 168, 67, 0.08);
    border-color: rgba(212, 168, 67, 0.12);
  }

  .plan-card--active .plan-card-btn--primary {
    background: #D4A843;
    border-color: #D4A843;
    color: #1A1A1A;
    box-shadow: 0 2px 16px rgba(212, 168, 67, 0.2);
  }

  .plan-card--active .plan-card-btn--primary:hover {
    background: #E0B84C;
    border-color: #E0B84C;
    box-shadow: 0 4px 24px rgba(212, 168, 67, 0.3);
    color: #1A1A1A;
  }

  .plan-card-content {
    position: relative;
    z-index: 1;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    flex: 1;
  }

  .plan-card-popular {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: var(--space-1-5);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: rgba(75, 163, 242, 0.08);
    border: 1px solid rgba(75, 163, 242, 0.1);
  }

  .plan-card-badge {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .plan-card-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .plan-amount {
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .plan-currency {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-tertiary);
    letter-spacing: 0.05em;
  }

  .plan-card-sub {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .plan-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .plan-card-list li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    line-height: var(--leading-normal);
  }

  .plan-card-list li svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .plan-card--lite .plan-card-list li svg {
    color: var(--color-text-tertiary);
  }

  .plan-card--active .plan-card-list li svg {
    color: #D4A843;
  }

  .plan-card-list-divider {
    height: 1px;
    background: var(--glass-border);
    margin: var(--space-1) 0;
  }

  .plan-card-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    align-self: flex-start;
    text-decoration: none;
    transition: all var(--transition-base);
    background: var(--glass-bg-strong);
    color: var(--color-text-secondary);
    border: 1px solid var(--glass-border);
  }

  .plan-card-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-primary);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .plan-card-btn--primary {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-text-primary);
    box-shadow: 0 2px 16px rgba(75, 163, 242, 0.2);
  }

  .plan-card-btn--primary:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    color: var(--color-text-primary);
    box-shadow: 0 4px 24px rgba(75, 163, 242, 0.3);
    transform: translateY(-1px);
  }

  .plan-card-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 1px 6px;
    border-radius: var(--radius-full);
    color: var(--color-text-tertiary);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    margin-left: var(--space-1);
    vertical-align: middle;
    line-height: 1.4;
  }

  .plan-card-tag--dev {
    color: rgba(75, 163, 242, 0.7);
    background: rgba(75, 163, 242, 0.06);
    border-color: rgba(75, 163, 242, 0.1);
  }

  .plan-card-note {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    opacity: 0.5;
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 32ch;
  }

  /* ── Collapsible details ── */
  .plan-details {
    margin-top: var(--space-8);
    border-radius: var(--radius-lg);
    background: transparent;
    border: 1px solid rgba(75, 163, 242, 0.08);
    overflow: hidden;
    transition: all var(--transition-base);
    position: relative;
  }



  .plan-info {
    margin-top: var(--space-10);
    position: relative;
    z-index: 1;
  }

  .plan-info-card {
    padding: var(--space-6) var(--space-8);
    border-radius: var(--radius-xl);
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
  }

  .plan-info-row {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
    padding: var(--space-3) 0;
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .plan-info-row + .plan-info-row {
    border-top: 1px solid var(--glass-border);
  }

  .plan-info-row strong {
    color: var(--color-text-primary);
    font-weight: 600;
    flex-shrink: 0;
  }

  .plan-info-icon {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: var(--radius-md);
    background: rgba(75, 163, 242, 0.08);
    color: var(--color-primary);
    padding: 7px;
    margin-top: 1px;
  }

  @media (max-width: 767px) {
    .plan-info-card {
      padding: var(--space-4) var(--space-5);
    }

    .plan-info-row {
      flex-direction: column;
      gap: var(--space-1-5);
    }
  }

  /* ══════════════════════════════════════════════════
     CURVED LOOP SEAL
     ══════════════════════════════════════════════════ */
  .curved-loop-seal {
    padding: 0;
    max-width: none;
    margin: 0;
  }

  .curved-loop-seal + * {
    margin-top: 0;
  }

  /* ══════════════════════════════════════════════════
     CONTACT SECTION — Abierto, sin card
     ══════════════════════════════════════════════════ */
  .section-contact {
    scroll-margin-top: 110px;
    overflow: hidden;
    text-align: center;
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-inner .section-header {
    text-align: center;
    max-width: 600px;
    margin-bottom: var(--space-12);
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    max-width: 800px;
    width: 100%;
  }

  .contact-card-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-6);
    background: var(--glass-bg-subtle);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .contact-card-item:hover {
    transform: translateY(-3px);
    border-color: rgba(75, 163, 242, 0.2);
    background: var(--glass-bg);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .contact-card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    opacity: 0.8;
    transition: all var(--transition-base);
  }

  .contact-card-item:hover .contact-card-icon {
    opacity: 1;
    transform: scale(1.1);
  }

  .contact-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.2;
  }

  .contact-card-detail {
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
    margin: 0;
    line-height: 1.4;
    opacity: 0.7;
    font-weight: 400;
  }

  .contact-card-item:hover .contact-card-detail {
    opacity: 1;
  }

  /* ══════════════════════════════════════════════════
     RESPONSIVE
     ══════════════════════════════════════════════════ */

  /* Tablet */
  @media (max-width: 1024px) {
    .lab-grid {
      grid-template-columns: 1fr;
    }

    .plans-grid {
      grid-template-columns: 1fr;
    }    .contact-cards {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .manifesto-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ══════════════════════════════════════════════════
     EDITORIAL NOTE — Trust Signals
     ══════════════════════════════════════════════════ */
  /* ══════════════════════════════════════════════════
     EDITORIAL SECTION
     ══════════════════════════════════════════════════ */
  .section-philosophy {
    position: relative;
    max-width: 900px;
  }



  /* ── TABLET (768px - 1023px) ── */
  @media (max-width: 1023px) {
    .hero-shader-bg {
      opacity: 0.25;
    }

    .hero-glass-panel--1 {
      width: 300px;
      height: 220px;
      right: -4%;
      opacity: 0.35;
    }

    .hero-glass-panel--2 {
      width: 240px;
      height: 160px;
      opacity: 0.25;
    }

    .hero-glass-panel--3 {
      display: none;
    }

    .hero-glass-panel--4 {
      display: none;
    }

.plans-grid {
      gap: var(--space-6);
    }
  }

  /* ── MOBILE: lighter backdrop-filter for performance, keep aesthetic ── */
  @media (max-width: 1023px) {
    .pillnav,
    .plan-card,
    .contact-card,
    .lab-card,
    .filosofia-carta,
    .process-grid,
    .process-desc-box,
    .doc-hero,
    .doc-content .step-section {
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
  }

  /* ── MOBILE (480px - 767px) ── */
  @media (max-width: 767px) {
    .pillnav {
      top: auto;
      bottom: var(--space-4);
      left: var(--space-4);
      right: var(--space-4);
      transform: none;
      width: auto;
      border-radius: var(--radius-xl);
      padding: 4px 6px;
      background: rgba(30, 30, 30, 0.85);
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      box-shadow: 0 4px 32px rgba(0, 0, 0, 0.35);
    }

    [data-theme="light"] .pillnav {
      background: rgba(240, 240, 240, 0.9);
    }

    .pillnav.visible {
      transform: none;
    }

    .pillnav-link {
      padding: var(--space-1) var(--space-3);
      gap: 4px;
    }

    .pillnav-label {
      font-size: 0.6rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 600;
      color: inherit;
    }

    .pillnav-icon {
      width: 16px;
      height: 16px;
    }

    .section {
      padding: var(--space-12) var(--space-5);
    }

    .section-header {
      margin-bottom: var(--space-8);
      max-width: 100%;
    }

    .section-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
      margin-bottom: var(--space-3);
    }

    .section-desc {
      font-size: var(--text-base);
    }

    .hero {
      padding: 100px var(--space-5) var(--space-12);
      min-height: auto;
    }

    .hero-title {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    .hero-sub {
      font-size: var(--text-sm);
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }

    .hero-shader-bg {
      opacity: 0.2;
    }

    .hero-glass-composition {
      opacity: 0.4;
    }

    .lab-grid {
      gap: var(--space-4);
    }

    .lab-card-content {
      padding: var(--space-6);
    }

    .process-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2);
      padding: var(--space-5);
    }

    .process-grid-step {
      flex-direction: row;
      gap: var(--space-5);
      padding: var(--space-3) var(--space-4);
      text-align: left;
    }

    .process-grid-num-wrap {
