---
// ══════════════════════════════════════════════════════════════
// MVGN Labs — Contact Page
// ══════════════════════════════════════════════════════════════

import DocsLayout from '../layouts/DocsLayout.astro';
import SupportCard from '../components/SupportCard.astro';
---

<DocsLayout title="Contacto" description="Estamos aquí para ayudarte.">
  <article class="contact-page">
    <header class="contact-header">
      <div class="contact-badge">Contacto</div>
      <h1 class="contact-title">¿Necesitas ayuda?</h1>
      <p class="contact-desc">
        Estamos aquí para asistirte en cada paso de tu configuración.
        Elige el canal que prefieras y te atenderemos lo antes posible.
      </p>
    </header>

    <section class="contact-channels">
      <SupportCard />
    </section>

    <section class="contact-info">
      <div class="contact-card">
        <h3 class="contact-card-title">Horario de Atención</h3>
        <p class="contact-card-text">
          Lunes a sábado · 9:00 AM — 8:00 PM<br />
          Domingos · 10:00 AM — 4:00 PM
        </p>
      </div>

      <div class="contact-card">
        <h3 class="contact-card-title">Tiempo de Respuesta</h3>
        <p class="contact-card-text">
          WhatsApp: <strong>Menos de 30 min</strong><br />
          Correo: <strong>Menos de 2 horas</strong>
        </p>
      </div>
    </section>
  </article>
</DocsLayout>

<style is:global>
  .contact-page {
    padding-bottom: var(--space-12);
  }

  .contact-header {
    max-width: var(--max-width-content);
  }

  .contact-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-badge {
    display: inline-flex;
    align-self: flex-start;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: var(--color-primary-subtle);
    color: var(--color-primary);
    border: 1px solid rgba(220, 38, 38, 0.15);
  }

  .contact-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .contact-desc {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 500px;
    line-height: var(--leading-relaxed);
  }

  .contact-channels {
    max-width: 500px;
  }

  .contact-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-card-title {
    font-size: var(--text-base);
    font-weight: 600;
  }

  .contact-card-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .contact-card-text strong {
    color: var(--color-text-primary);
  }

  @media (max-width: 640px) {
    .contact-title {
      font-size: var(--text-3xl);
    }

    .contact-info {
      grid-template-columns: 1fr;
    }
  }
</style>
