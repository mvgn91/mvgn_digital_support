          <p class="hero-sub animate-in in-view">
            Implementación, documentación y soporte técnico para experiencias de entretenimiento digital en Android y múltiples dispositivos.
          </p>

          <div class="hero-actions animate-in in-view">
            <a href="#experiencias" class="btn btn--primary">
              Ver soluciones
              <ArrowRight size={18} />
            </a>
            <a href="https://wa.me/523322621939" target="_blank" rel="noopener noreferrer" class="btn btn--glass">
              <MessageCircle size={18} />
              Hablar por WhatsApp
            </a>
          </div>


        </div>

        <!-- ── Right: Cascading Screens ── -->
        <div class="hero-visual">
          <div class="hero-visual-bg" aria-hidden="true"></div>
          <CascadeMobileScreens client:load images={{
            streaming: "/material%20design%20mockup%201.png",
            addon: "/material%20design%20mockup%202.png",
            blog: "/material%20design%20mockup%203.png",
          }} />
        </div>

      </div>
    </header>

    <!-- ═══ SECTION 2: DOS SOLUCIONES ═══ -->
    <section class="section" id="experiencias" style="scroll-margin-top: 110px;">
      <div class="section-header animate-in">
