---
// ══════════════════════════════════════════════════════════════
// MVGN Labs — ScreenshotFrame Component
// ══════════════════════════════════════════════════════════════

export interface Props {
  src: string;
  alt: string;
  caption?: string;
  variant?: 'phone' | 'phone-pair' | 'desktop';
  annotations?: {
    number: number;
    text: string;
    position?: 'top-right' | 'middle-right' | 'bottom-right' | 'top-left' | 'middle-left' | 'bottom-left';
  }[];
}

const { src, alt, caption, variant = 'phone', annotations = [] } = Astro.props;

const positionClasses: Record<string, string> = {
  'top-right': 'ann-tr',
  'middle-right': 'ann-mr',
  'bottom-right': 'ann-br',
  'top-left': 'ann-tl',
  'middle-left': 'ann-ml',
  'bottom-left': 'ann-bl',
};
---

<figure class:list={{
  'ss-frame': true,
  [`ss-frame--${variant}`]: true,
}}>
  <div class="ss-image-wrap">
    <img src={src} alt={alt} loading="lazy" />
    {annotations.map((ann) => (
      <div class:list={['ann', positionClasses[ann.position || 'middle-right'] || 'ann-mr']}>
        <span class="ann-dot">{ann.number}</span>
        <span class="ann-label">{ann.text}</span>
      </div>
    ))}
  </div>
  {caption && <figcaption class="ss-caption">{caption}</figcaption>}
</figure>

<style is:global>
  .ss-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
  }

  .ss-image-wrap {
    position: relative;
    width: 100%;
    max-width: 280px;
    line-height: 0;
  }

  .ss-frame--desktop .ss-image-wrap {
    max-width: 100%;
  }

  .ss-frame--phone-pair {
    flex-direction: row;
    justify-content: center;
    gap: var(--space-4);
  }

  .ss-frame--phone-pair .ss-image-wrap {
    max-width: 180px;
  }

  .ss-frame--phone-pair .ss-caption {
    display: none;
  }

  .ss-image-wrap img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.2);
  }

  .ss-caption {
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    text-align: center;
    line-height: 1.5;
    max-width: 80%;
  }

  /* Annotations — inline label style */
  .ann {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    z-index: 5;
    pointer-events: none;
  }

  .ann-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.3);
  }

  .ann-label {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-text-primary);
    line-height: 1.2;
    background: rgba(17, 17, 17, 0.9);
    padding: 2px 8px;
    border-radius: 4px;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .ann-tr { top: 12%; right: -20px; }
  .ann-mr { top: 46%; right: -20px; }
  .ann-br { top: 74%; right: -20px; }
  .ann-tl { top: 12%; left: -20px; }
  .ann-ml { top: 46%; left: -20px; }
  .ann-bl { top: 74%; left: -20px; }

  .ann-tl,
  .ann-ml,
  .ann-bl {
    flex-direction: row-reverse;
  }

  @media (max-width: 640px) {
    .ann { display: none; }
    .ss-caption { max-width: 100%; }
  }
</style>
